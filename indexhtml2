<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FL 2-14 Exam Simulator — 361 Questions</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Source+Sans+3:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #0a0f1a;
  --bg2: #111827;
  --bg3: #1a2233;
  --accent: #3b82f6;
  --accent2: #60a5fa;
  --gold: #f59e0b;
  --gold2: #fcd34d;
  --green: #10b981;
  --red: #ef4444;
  --text: #e2e8f0;
  --muted: #64748b;
  --border: rgba(255,255,255,0.07);
  --card: rgba(255,255,255,0.03);
}
*{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
body{
  font-family:'Source Sans 3',sans-serif;
  background:var(--bg);
  color:var(--text);
  min-height:100vh;
  overflow-x:hidden;
}
body::after{
  content:'';
  position:fixed;
  inset:0;
  background:
    radial-gradient(ellipse 100% 50% at 50% -20%, rgba(59,130,246,0.1) 0%, transparent 60%),
    radial-gradient(ellipse 60% 40% at 90% 90%, rgba(245,158,11,0.05) 0%, transparent 50%);
  pointer-events:none;
  z-index:0;
}

/* SCREENS */
.screen{display:none;position:relative;z-index:1;}
.screen.active{display:block;}

/* ── HOME ── */
#home{
min-height:100vh;
display:flex;flex-direction:column;align-items:center;justify-content:center;
padding:40px 20px;text-align:center;
}
.exam-tag{
font-family:‘JetBrains Mono’,monospace;font-size:11px;letter-spacing:.25em;
text-transform:uppercase;color:var(–accent2);
border:1px solid rgba(59,130,246,.35);background:rgba(59,130,246,.08);
padding:6px 16px;border-radius:100px;margin-bottom:32px;display:inline-block;
}
.home-title{
font-family:‘Playfair Display’,serif;font-size:clamp(42px,9vw,80px);
line-height:1;margin-bottom:20px;
background:linear-gradient(135deg,#fff 0%,var(–accent2) 60%,var(–gold2) 100%);
-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.home-sub{font-size:17px;color:var(–muted);margin-bottom:12px;max-width:500px;}
.home-meta{
font-family:‘JetBrains Mono’,monospace;font-size:13px;color:var(–gold);
margin-bottom:52px;
}
.info-cards{
display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));
gap:14px;max-width:720px;width:100%;margin-bottom:48px;
}
.info-card{
background:var(–card);border:1px solid var(–border);border-radius:14px;
padding:20px 16px;text-align:center;
}
.info-card-num{
font-family:‘Playfair Display’,serif;font-size:36px;
color:var(–accent2);display:block;margin-bottom:4px;
}
.info-card-lbl{font-size:12px;color:var(–muted);letter-spacing:.05em;}

.start-area{display:flex;flex-direction:column;align-items:center;gap:16px;margin-bottom:48px;}
.btn-start{
font-family:‘Source Sans 3’,sans-serif;font-size:17px;font-weight:600;
padding:16px 48px;border-radius:12px;border:none;cursor:pointer;
background:linear-gradient(135deg,var(–accent),#1d4ed8);
color:#fff;letter-spacing:.03em;
box-shadow:0 4px 24px rgba(59,130,246,.35);
transition:all .2s;
}
.btn-start:hover{transform:translateY(-2px);box-shadow:0 8px 32px rgba(59,130,246,.5);}
.session-note{font-size:13px;color:var(–muted);}

.progress-section{max-width:720px;width:100%;}
.progress-title{
font-size:12px;letter-spacing:.15em;text-transform:uppercase;
color:var(–muted);font-family:‘JetBrains Mono’,monospace;
margin-bottom:16px;text-align:left;
}
.overall-bar{
height:8px;background:rgba(255,255,255,.06);border-radius:100px;
overflow:hidden;margin-bottom:12px;
}
.overall-fill{
height:100%;border-radius:100px;
background:linear-gradient(90deg,var(–accent),var(–gold));
transition:width .5s ease;
}
.overall-stats{display:flex;justify-content:space-between;font-size:13px;color:var(–muted);}
.overall-stats span{font-family:‘JetBrains Mono’,monospace;}
.overall-stats .hi{color:var(–accent2);}

.reset-btn{
margin-top:20px;font-size:12px;color:var(–muted);background:none;
border:1px solid var(–border);border-radius:6px;padding:6px 14px;
cursor:pointer;font-family:‘Source Sans 3’,sans-serif;transition:all .2s;
}
.reset-btn:hover{color:var(–red);border-color:rgba(239,68,68,.4);}

/* ── QUIZ ── */
#quiz{max-width:800px;margin:0 auto;padding:32px 20px 100px;}

.quiz-nav{
display:flex;align-items:center;justify-content:space-between;
margin-bottom:28px;flex-wrap:wrap;gap:12px;
}
.back-btn{
font-family:‘Source Sans 3’,sans-serif;font-size:13px;color:var(–muted);
background:none;border:1px solid var(–border);border-radius:8px;
padding:8px 14px;cursor:pointer;transition:all .2s;
}
.back-btn:hover{color:var(–text);border-color:rgba(255,255,255,.2);}
.quiz-prog-text{font-family:‘JetBrains Mono’,monospace;font-size:13px;color:var(–muted);}
.session-tag{
font-size:11px;letter-spacing:.15em;text-transform:uppercase;
color:var(–accent2);font-family:‘JetBrains Mono’,monospace;
background:rgba(59,130,246,.1);border:1px solid rgba(59,130,246,.25);
padding:4px 10px;border-radius:6px;
}

.prog-bar-wrap{height:3px;background:rgba(255,255,255,.06);border-radius:100px;margin-bottom:28px;overflow:hidden;}
.prog-bar-fill{height:100%;background:linear-gradient(90deg,var(–accent),var(–accent2));border-radius:100px;transition:width .4s ease;}

.live-scores{display:flex;gap:14px;margin-bottom:28px;flex-wrap:wrap;}
.live-chip{
font-family:‘JetBrains Mono’,monospace;font-size:13px;
padding:6px 14px;border-radius:8px;font-weight:500;
}
.live-chip.c{background:rgba(16,185,129,.1);color:var(–green);border:1px solid rgba(16,185,129,.25);}
.live-chip.w{background:rgba(239,68,68,.1);color:var(–red);border:1px solid rgba(239,68,68,.25);}
.live-chip.s{background:rgba(245,158,11,.1);color:var(–gold);border:1px solid rgba(245,158,11,.25);}

.cat-tag{
font-size:11px;letter-spacing:.18em;text-transform:uppercase;
color:var(–gold2);font-family:‘JetBrains Mono’,monospace;margin-bottom:14px;display:block;
}
.q-card{
background:var(–card);border:1px solid var(–border);border-radius:20px;
padding:36px;margin-bottom:22px;animation:fsin .3s ease;
}
@keyframes fsin{from{opacity:0;transform:translateY(10px);}to{opacity:1;transform:translateY(0);}}
.q-num{font-family:‘JetBrains Mono’,monospace;font-size:12px;color:var(–muted);margin-bottom:14px;}
.q-text{font-size:19px;line-height:1.6;color:#d1dde8;font-weight:400;}

.answers{display:flex;flex-direction:column;gap:11px;margin-bottom:22px;}
.ans-btn{
display:flex;align-items:flex-start;gap:14px;
background:rgba(255,255,255,.02);border:1px solid var(–border);
border-radius:12px;padding:15px 20px;cursor:pointer;text-align:left;
font-family:‘Source Sans 3’,sans-serif;font-size:15px;color:var(–text);
transition:all .2s ease;line-height:1.45;
}
.ans-btn:hover:not(:disabled){
background:rgba(59,130,246,.07);border-color:rgba(59,130,246,.35);transform:translateX(4px);
}
.ans-btn .ltr{
flex-shrink:0;width:28px;height:28px;border-radius:7px;
background:rgba(255,255,255,.05);display:flex;align-items:center;justify-content:center;
font-family:‘JetBrains Mono’,monospace;font-size:12px;color:var(–muted);
transition:all .2s;margin-top:1px;
}
.ans-btn.cor{background:rgba(16,185,129,.09);border-color:rgba(16,185,129,.4);color:#a7f3d0;}
.ans-btn.cor .ltr{background:var(–green);color:#fff;}
.ans-btn.wrg{background:rgba(239,68,68,.07);border-color:rgba(239,68,68,.35);color:#fca5a5;}
.ans-btn.wrg .ltr{background:var(–red);color:#fff;}
.ans-btn.dim{opacity:.35;}
.ans-btn:disabled{cursor:default;}

.fb-box{border-radius:14px;padding:20px 24px;font-size:14px;line-height:1.65;display:none;margin-bottom:22px;animation:fsin .25s ease;}
.fb-box.cor{display:block;background:rgba(16,185,129,.07);border:1px solid rgba(16,185,129,.22);color:#bbf7d0;}
.fb-box.wrg{display:block;background:rgba(239,68,68,.07);border:1px solid rgba(239,68,68,.2);color:#fecaca;}
.fb-title{font-weight:700;font-size:15px;margin-bottom:6px;}
.fb-box.cor .fb-title{color:var(–green);}
.fb-box.wrg .fb-title{color:var(–red);}
.fb-ref{margin-top:10px;padding-top:10px;border-top:1px solid rgba(255,255,255,.06);color:var(–muted);font-size:13px;}
.fb-ref strong{color:var(–text);}

.nav-btns{display:flex;gap:12px;flex-wrap:wrap;}
.btn{
font-family:‘Source Sans 3’,sans-serif;font-size:14px;font-weight:600;
padding:12px 26px;border-radius:10px;border:none;cursor:pointer;
transition:all .2s;letter-spacing:.02em;
}
.btn-p{background:var(–accent);color:#fff;}
.btn-p:hover{background:var(–accent2);transform:translateY(-1px);}
.btn-s{background:rgba(255,255,255,.05);color:var(–muted);border:1px solid var(–border);}
.btn-s:hover{background:rgba(255,255,255,.09);color:var(–text);}

/* ── RESULTS ── */
#results{max-width:680px;margin:0 auto;padding:60px 20px;text-align:center;}
.res-icon{font-size:72px;margin-bottom:24px;display:block;}
.res-title{font-family:‘Playfair Display’,serif;font-size:46px;margin-bottom:12px;}
.res-sub{font-size:16px;color:var(–muted);margin-bottom:40px;}
.res-pct{font-family:‘Playfair Display’,serif;font-size:88px;line-height:1;margin-bottom:10px;color:var(–accent2);}
.pass-label{font-size:18px;font-weight:600;margin-bottom:40px;}
.pass-label.p{color:var(–green);}
.pass-label.f{color:var(–red);}
.res-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:40px;}
.res-cell{background:var(–card);border:1px solid var(–border);border-radius:14px;padding:22px 12px;}
.res-cell-n{font-family:‘Playfair Display’,serif;font-size:36px;display:block;margin-bottom:4px;}
.res-cell-l{font-size:12px;color:var(–muted);}
.res-cell.c .res-cell-n{color:var(–green);}
.res-cell.w .res-cell-n{color:var(–red);}
.res-cell.s .res-cell-n{color:var(–gold);}
.res-btns{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;}
.overall-prog-note{
font-size:13px;color:var(–muted);margin-top:24px;
font-family:‘JetBrains Mono’,monospace;
}

@media(max-width:500px){
.q-card{padding:22px 16px;}
.q-text{font-size:16px;}
.res-pct{font-size:64px;}
.res-grid{grid-template-columns:1fr 1fr 1fr;}
}
</style>

</head>
<body>

<!-- HOME -->

<div id="home" class="screen active">
  <span class="exam-tag">Florida 2-14 · Life &amp; Annuity · Variable Contracts</span>
  <h1 class="home-title">Exam<br>Simulator</h1>
  <p class="home-sub">All 361 real exam questions from your study material.</p>
  <p class="home-meta">100 questions per session · 85 scored on real exam · 70% to pass (60/85)</p>

  <div class="info-cards">
    <div class="info-card">
      <span class="info-card-num">361</span>
      <span class="info-card-lbl">Total Questions</span>
    </div>
    <div class="info-card">
      <span class="info-card-num">100</span>
      <span class="info-card-lbl">Per Session</span>
    </div>
    <div class="info-card">
      <span class="info-card-num">70%</span>
      <span class="info-card-lbl">Pass Threshold</span>
    </div>
    <div class="info-card">
      <span class="info-card-num">2hr</span>
      <span class="info-card-lbl">Time Limit</span>
    </div>
  </div>

  <div class="start-area">
    <button class="btn-start" onclick="startSession()">Start 100-Question Session →</button>
    <span class="session-note" id="session-note"></span>
  </div>

  <div class="progress-section">
    <div class="progress-title">Overall Progress Through All 361 Questions</div>
    <div class="overall-bar"><div class="overall-fill" id="overall-fill"></div></div>
    <div class="overall-stats">
      <span>Seen: <span class="hi" id="stat-seen">0</span> / 361</span>
      <span>Correct: <span class="hi" id="stat-correct">0</span></span>
      <span>Score: <span class="hi" id="stat-score">—</span></span>
    </div>
    <button class="reset-btn" onclick="resetAll()">Reset All Progress</button>
  </div>
</div>

<!-- QUIZ -->

<div id="quiz" class="screen">
  <div class="quiz-nav">
    <button class="back-btn" onclick="goHome()">← Home</button>
    <span class="quiz-prog-text" id="prog-text"></span>
    <span class="session-tag" id="session-tag"></span>
  </div>
  <div class="prog-bar-wrap"><div class="prog-bar-fill" id="prog-fill"></div></div>
  <div class="live-scores">
    <span class="live-chip c" id="lc">✓ 0</span>
    <span class="live-chip w" id="lw">✗ 0</span>
    <span class="live-chip s" id="ls">↷ 0</span>
  </div>
  <span class="cat-tag" id="cat-tag"></span>
  <div class="q-card">
    <div class="q-num" id="q-num"></div>
    <div class="q-text" id="q-text"></div>
  </div>
  <div class="answers" id="answers"></div>
  <div class="fb-box" id="fb"></div>
  <div class="nav-btns">
    <button class="btn btn-p" id="next-btn" onclick="nextQ()" style="display:none">Next →</button>
    <button class="btn btn-s" onclick="skipQ()">Skip</button>
  </div>
</div>

<!-- RESULTS -->

<div id="results" class="screen">
  <span class="res-icon" id="ri"></span>
  <div class="res-title" id="rt"></div>
  <div class="res-sub" id="rs"></div>
  <div class="res-pct" id="rp"></div>
  <div class="pass-label" id="rl"></div>
  <div class="res-grid">
    <div class="res-cell c"><span class="res-cell-n" id="rc"></span><span class="res-cell-l">Correct</span></div>
    <div class="res-cell w"><span class="res-cell-n" id="rw"></span><span class="res-cell-l">Wrong</span></div>
    <div class="res-cell s"><span class="res-cell-n" id="rsk"></span><span class="res-cell-l">Skipped</span></div>
  </div>
  <div class="res-btns">
    <button class="btn btn-p" onclick="startSession()">New Session →</button>
    <button class="btn btn-s" onclick="goHome()">← Home</button>
  </div>
  <div class="overall-prog-note" id="prog-note"></div>
</div>

<script>
// ═══════════════════════════════════════════════════════════════
// ALL 361 QUESTIONS — sourced directly from your PDF Q&A pairs
// ═══════════════════════════════════════════════════════════════
const QBANK = [
// --- POLICY TYPES & CONCEPTS ---
{c:"Policy Types",q:"What percentage of eligible persons must a policy cover in a noncontributory group?",o:["50%","75%","100%","It varies by state"],a:2,e:"Noncontributory group plans (employer pays full premium) require 100% participation of all eligible employees."},
{c:"Policy Types",q:"T is an employee covered under a Group Life policy. If T's employment is terminated, the conversion privilege gives T the right to:",o:["Keep the group policy at group rates","Convert to an individual policy upon employment termination","Convert only to term insurance","Receive a cash refund"],a:1,e:"Upon termination, a group life insured may convert to an individual policy without evidence of insurability within 31 days."},
{c:"FL Regulations",q:"What are adjustable rates for life policy loans in Florida based on?",o:["Prime rate","Moody's corporate bond index","Federal funds rate","S&P 500 index"],a:1,e:"Florida adjustable policy loan rates are based on Moody's Corporate Bond Yield Average."},
{c:"Underwriting",q:"Which of the following can an agent provide to help a prospective client understand and purchase the most appropriate product?",o:["Policy illustration","Buyer's guide","MIB report","Prospectus"],a:1,e:"A Buyer's Guide is required to be provided to prospective purchasers to help them understand and select appropriate coverage."},
{c:"FL Regulations",q:"Which of the following factors is NOT considered when the Department of Financial Services determines if an agent's home is an insurance agency?",o:["Whether clients visit the home","Whether records are kept there","The amount of premium collected at this location","Whether insurance is transacted there"],a:2,e:"The amount of premium collected is not a determining factor in whether a home qualifies as an insurance agency location."},
{c:"FL Regulations",q:"Which of the following situations does NOT apply to the Florida Replacement Rule?",o:["A new policy replaces an existing one from a different insurer","A policy is modified to reduce benefits","An existing policyholder purchases an additional policy from the same insurer","A policy is surrendered to fund a new one"],a:2,e:"Purchasing an additional policy from the same insurer without replacing an existing one is not subject to replacement regulations."},
{c:"Unfair Practices",q:"Convincing a prospective insured to buy an insurance policy based on exaggerations is called:",o:["Twisting","Churning","Misrepresentation","Rebating"],a:2,e:"Misrepresentation involves making false or exaggerated statements to induce someone to purchase a policy."},
{c:"FL Regulations",q:"Which two entities regulate variable annuities?",o:["DFS and the Federal Reserve","Department of Financial Services and Securities Exchange Commission","OIR and FINRA","DFS and NAIC"],a:1,e:"Variable annuities are regulated by the FL DFS (insurance) and the SEC (securities side)."},
{c:"FL Regulations",q:"Which of the following is NOT a consequence for placing business with an unauthorized insurer?",o:["License suspension","Civil penalty","First degree misdemeanor","Fines"],a:2,e:"Placing business with an unauthorized insurer can result in license suspension, fines, and civil penalties — but not a first-degree misdemeanor specifically."},
{c:"Underwriting",q:"During the application process, the agent's primary responsibility is to:",o:["The applicant","The beneficiary","The insurance company","The state regulator"],a:2,e:"The agent acts as a representative of the insurance company, not the applicant, during the application process."},
{c:"Underwriting",q:"Omitting information that affects the issuance or the rate of an insurance contract is called:",o:["Misrepresentation","Fraud","Concealment","Twisting"],a:2,e:"Concealment is the intentional withholding of material facts that could affect the issuance or premium of a policy."},
{c:"FL Regulations",q:"Which professional organization has its code of ethics incorporated into Florida law?",o:["NAIC","LIMRA","National Association of Insurance and Financial Advisors (NAIFA)","ACLI"],a:2,e:"NAIFA's code of ethics is specifically incorporated into Florida insurance law."},
{c:"FL Regulations",q:"In Florida, agents are allowed to engage in rebating if:",o:["The client requests it","Offered to all insureds in the same actuarial class","The item is worth less than $50","The insurer approves it"],a:1,e:"Rebating is only permissible in FL if offered equally to all insureds in the same actuarial class. Items ≤$25 are also permitted."},
{c:"FL Regulations",q:"Which organization was established to provide funds to protect an insured in the event of an insurer's insolvency?",o:["NAIC","Florida Insurance Guaranty Fund Association","Department of Financial Services","Federal Deposit Insurance Corporation"],a:1,e:"The Florida Insurance Guaranty Association (FIGA) protects policyholders if a licensed insurer becomes insolvent."},
{c:"FL Regulations",q:"In Florida, an insurer domiciled and incorporated in this state is called a(n):",o:["Foreign company","Alien company","Domestic company","Admitted company"],a:2,e:"A domestic company is incorporated and domiciled in the state where it primarily operates."},
{c:"FL Regulations",q:"A variable life insurance agent must be licensed and appointed as a life and variable contract agent, as well as a(n):",o:["Registered investment advisor","Broker dealer","Securities dealer","NASD member"],a:1,e:"Variable life agents must hold a life & variable contract license AND be associated with a registered broker-dealer."},
{c:"Unfair Practices",q:"Which Unfair Trade Practice involves making a false statement on an insurance application in order to receive money from an insurer?",o:["Twisting","Churning","Rebating","Misrepresentation"],a:3,e:"Misrepresentation includes making false statements on applications to fraudulently obtain insurance benefits."},
{c:"FL Regulations",q:"Who is a mutual insurance company owned by?",o:["Shareholders","The state","Its policyholders","The management"],a:2,e:"A mutual insurance company is owned by its policyholders, who may receive dividends."},
{c:"FL Regulations",q:"An agent that sells Variable Life insurance MUST be registered with:",o:["The SEC","The Federal Reserve","Financial Industry Regulatory Authority (FINRA)","The Department of Financial Services"],a:2,e:"Variable life is a security product; agents must register with FINRA before selling it."},
{c:"FL Regulations",q:"All of these are a prerequisite for becoming a licensed agent EXCEPT:",o:["Being at least 18 years old","Passing the state exam","Graduate from high school","Being a Florida resident or qualifying non-resident"],a:2,e:"A high school diploma is NOT required to become a licensed insurance agent in Florida."},
{c:"FL Regulations",q:"Insurance companies that are organized in countries outside the United States are referred to as:",o:["Foreign","Domestic","Alien","Non-admitted"],a:2,e:"Alien companies are organized outside the United States. Foreign companies are organized in another U.S. state."},
{c:"Ethics",q:"T is an agent and when hired, is reminded that he has a responsibility to handle clients' funds in an honest and ethical manner. This responsibility is referred to as:",o:["Express authority","Apparent authority","Fiduciary responsibility","Implied authority"],a:2,e:"Fiduciary responsibility means agents must handle client funds honestly and in the clients' best interests."},
{c:"Business Insurance",q:"In a Key Employee life insurance policy, the third-party owner can be all of the following, EXCEPT:",o:["The employer","A business partner","The insured","A corporation"],a:2,e:"In key person insurance, the insured cannot be the owner — the business entity owns the policy on the key employee."},
{c:"Underwriting",q:"Which of these factors does NOT influence an applicant's need for life insurance?",o:["Number of dependents","Annual income","Self-maintenance expenses","Existing debts"],a:2,e:"Self-maintenance expenses (the insured's own living costs) are not a factor in determining life insurance need for others."},
{c:"FL Regulations",q:"An agent's license can be suspended or revoked by writing primarily controlled business. Controlled business is defined as:",o:["Business from strangers only","Insurance primarily on the agent, their family, or employer","Business written for commissions","Business written outside Florida"],a:1,e:"Controlled business is insurance primarily on the agent, their family members, or employer. FL limits this to 50% of total business."},
{c:"Business Insurance",q:"Which of these is NOT a reason for a business to buy key person life insurance?",o:["To protect against loss of revenue from the key employee's death","To fund recruitment of a replacement","A pension deficiency if the key employee dies","To cover training costs for a replacement"],a:2,e:"Key person insurance covers loss of revenue, recruitment, and replacement costs — not pension deficiencies."},
{c:"Retirement",q:"What does a 401(k) plan generally provide its participants?",o:["Employer-only contributions","Defined monthly pension benefits","Salary-deferral contributions","Tax-free withdrawals at any age"],a:2,e:"A 401(k) allows employees to defer a portion of their salary pre-tax into a retirement account."},
{c:"Retirement",q:"What determines the full amount of Social Security retirement benefits a qualified individual is entitled to receive?",o:["Years of service","Age at retirement","Primary Insurance Amount (PIA)","Number of dependents"],a:2,e:"The Primary Insurance Amount (PIA) is the formula-based amount that determines full Social Security retirement benefits."},
{c:"Retirement",q:"Which tax would an IRA participant be subjected to on distributions received prior to age 59½?",o:["Capital gains tax only","Ordinary income tax only","Ordinary income tax and a 10% penalty for early withdrawal","10% penalty only"],a:2,e:"Early distributions from traditional IRAs are subject to ordinary income tax PLUS a 10% IRS penalty."},
{c:"Retirement",q:"A 55-year-old recently received a $30,000 distribution from a previous employer's 401k plan, minus $6,000 withholding. Which federal taxes apply if none of the funds were rolled over?",o:["Only income tax on $24,000","Income taxes plus a 10% penalty tax on $30,000","Only the 10% penalty on $30,000","Income taxes on $24,000 plus 10% penalty on $24,000"],a:1,e:"The full $30,000 is subject to income tax and 10% early withdrawal penalty. The $6,000 withheld counts as a credit against taxes owed."},
{c:"Retirement",q:"What is Old Age and Survivors Health Insurance (OASDHI) also known as?",o:["Medicare","Medicaid","Social Security","ERISA"],a:2,e:"OASDHI is the formal name for Social Security, which covers old age, survivors, disability, and hospital insurance."},
{c:"Retirement",q:"Which of the following does Social Security NOT provide benefits for?",o:["Retirement","Disability","Survivors","Dismemberment"],a:3,e:"Social Security provides retirement, disability, and survivor benefits — but NOT dismemberment benefits (that's AD&D insurance)."},
{c:"Retirement",q:"A retirement plan that sets aside part of the company's net income for distributions to qualified employees is called a:",o:["Defined benefit plan","Keogh plan","Profit-sharing plan","SIMPLE IRA"],a:2,e:"A profit-sharing plan distributes a portion of company profits to eligible employees' retirement accounts."},
{c:"Underwriting",q:"An applicant's medical information received from the Medical Information Bureau (MIB) may be furnished to the:",o:["General public","Applicant's attorney","Applicant's physician","Any other insurer"],a:2,e:"MIB medical information can be shared with the applicant's physician — not directly to the applicant, attorney, or other insurers without authorization."},
{c:"Retirement",q:"The amount of monthly disability benefits payable under Social Security is affected by which of the following factors?",o:["The applicant's age at application","Amount of the benefits available from other sources","Number of dependents","Type of disability"],a:1,e:"Social Security disability benefits can be affected (offset) by workers' compensation or other public disability benefits."},
{c:"FL Regulations",q:"Life insurance companies are required to establish and maintain an anti-money laundering compliance program according to which federal regulation?",o:["Fair Credit Reporting Act","ERISA","USA Patriot Act","Gramm-Leach-Bliley Act"],a:2,e:"The USA Patriot Act requires life insurers to implement anti-money laundering (AML) compliance programs."},
{c:"Policy Types",q:"Which of these statements describe a Modified Endowment Contract (MEC)?",o:["A policy that lapses due to non-payment","A term policy converted to whole life","Exceeds the maximum amount of premium that can be paid into a policy and still be recognized as life insurance","A policy with no cash value"],a:2,e:"A MEC fails the 7-pay test by being overfunded beyond IRS limits, causing it to lose favorable life insurance tax treatment on withdrawals."},
{c:"Retirement",q:"Which of these is NOT a source of funding for Social Security benefits?",o:["Employee FICA taxes","Employer FICA taxes","Federal Government","Self-employment taxes"],a:2,e:"Social Security is funded by FICA taxes from employees and employers — NOT by general federal government revenue."},
{c:"Policy Types",q:"Additional coverage can be added to a Whole Life policy by adding a(n):",o:["Variable rider","Increasing term rider","Decreasing term rider","Universal life rider"],a:2,e:"A decreasing term rider can be added to a whole life policy to provide additional decreasing coverage (e.g. mortgage protection)."},
{c:"Policy Types",q:"N is a 40-year-old applicant who would like to retire at age 70. He is looking to buy a life insurance policy with level premiums, permanent protection, and be paid-up at retirement. Which of these should N purchase?",o:["Straight Whole Life","20-Pay Life","30 Pay Life","Universal Life"],a:2,e:"30-Pay Life has premiums paid over 30 years (age 40 to 70), providing paid-up permanent coverage at retirement."},
{c:"Policy Types",q:"Whole Life insurance is sometimes referred to as 'Straight Life'. What does the word 'Straight' indicate when using this phrase?",o:["The level death benefit","The duration of premium payments","The straight-line growth of cash value","The policy never changes"],a:1,e:"'Straight' in Straight Life refers to paying premiums for the entire (straight) duration of the insured's life to age 100."},
{c:"Provisions",q:"A long-term care rider in a life insurance policy pays a daily benefit in the event of which of the following?",o:["Terminal illness only","Disability from an accident","Inability of the insured to perform more than 2 Activities of Daily Living (ADLs)","Any hospitalization"],a:2,e:"The LTC rider triggers when the insured cannot perform 2 or more of the 6 Activities of Daily Living (ADLs) or has cognitive impairment."},
{c:"Policy Types",q:"Whole Life insurance policies are contractually guaranteed to provide each of the following, EXCEPT:",o:["Level premiums","Death benefit","Cash value accumulation","Partial withdrawal features beyond a surrender charge period"],a:3,e:"Whole Life does not guarantee partial withdrawal features — you can surrender or take loans, but not partial withdrawals like in UL."},
{c:"Provisions",q:"Which of these statements about a Guaranteed Insurability Option rider is NOT TRUE?",o:["It allows purchase of additional coverage at specified dates","No evidence of insurability is required at option dates","Evidence of insurability is required when the option is exercised","The option can be exercised at life events like marriage or birth"],a:2,e:"The GIR specifically allows additional coverage WITHOUT evidence of insurability at specified dates — that's its main benefit."},
{c:"Retirement",q:"How are Roth IRA distributions normally taxed?",o:["As ordinary income","Subject to 10% penalty","Distributions are received tax-free","As capital gains"],a:2,e:"Roth IRA contributions are made with after-tax dollars; qualified distributions are completely income tax-free."},
{c:"Underwriting",q:"The insurer MUST advise her in writing that an investigative consumer report may be conducted according to the:",o:["USA Patriot Act","ERISA","Fair Credit Reporting Act","Florida Insurance Code"],a:2,e:"The Fair Credit Reporting Act (FCRA) requires insurers to notify applicants in writing before ordering investigative consumer reports."},
{c:"Underwriting",q:"What is the initial source of underwriting for an insurance policy?",o:["MIB report","Inspection report","Application containing statements from the insured","Attending physician statement"],a:2,e:"The application is the initial and primary source of underwriting information."},
{c:"Provisions",q:"Whose life is covered on a life insurance policy that contains a payor benefit clause?",o:["The payor","The policyowner","Child","The beneficiary"],a:2,e:"The payor benefit (payor provision) covers a child's policy — premiums are waived if the adult payor dies or becomes disabled."},
{c:"Underwriting",q:"An agent gives a conditional receipt to a client for an insurance policy after collecting the initial premium. When will the policy become effective?",o:["Immediately regardless of underwriting","When the conditions of the receipt are met","When the policy is delivered","After 30 days"],a:1,e:"A conditional receipt provides coverage from the application date IF the conditions (passing underwriting) are met."},
{c:"Business Insurance",q:"Who benefits in Investor-Originated Life Insurance (IOLI) when the insured dies?",o:["The insured's family","The insurance company","The policyowner (investor)","The state"],a:2,e:"In IOLI/STOLI arrangements, the investor (policyowner) collects the death benefit — not the insured's family. This circumvents insurable interest."},
{c:"Underwriting",q:"Information obtained from a phone conversation to the proposed insured can be found in which of these reports?",o:["MIB report","Attending Physician Statement","Inspection report","Credit report"],a:2,e:"An inspection report includes information gathered through interviews, including phone conversations with the proposed insured."},
{c:"Underwriting",q:"ABC Insurance Company has accepted a life insurance application which contains unanswered questions. The company then makes the application part of the life contract. In this situation, the insurer has:",o:["Committed fraud","Violated Florida law","Waived one of its legal rights","Made the policy voidable"],a:2,e:"By accepting an incomplete application and making it part of the contract, the insurer waives its right to contest based on those blank answers."},
{c:"Underwriting",q:"What action should a producer take if the initial premium is NOT submitted with the application?",o:["Return the application to the applicant","Collect the premium before submitting","Forward the application to the insurer without the initial premium","Provide a conditional receipt anyway"],a:2,e:"Without the initial premium, the agent forwards the application only; no receipt is issued and coverage doesn't begin until policy delivery and premium payment."},
{c:"Taxation",q:"Which of these statements is CORRECT regarding the tax treatment of a lump-sum payment paid to a life insurance policy's primary beneficiary?",o:["Subject to estate tax","Taxable as ordinary income","Subject to capital gains tax","All proceeds are income tax free in the year they are received"],a:3,e:"Life insurance death benefits paid as a lump sum to a named beneficiary are received income-tax free."},
{c:"Policy Types",q:"Which of these types of policies may NOT have the Automatic Premium Loan provision attached to it?",o:["Whole Life","Universal Life","Decreasing Term","Straight Life"],a:2,e:"Automatic Premium Loans require cash value to function. Term policies (including decreasing term) have no cash value, so the provision cannot apply."},
{c:"Policy Types",q:"K purchased a Life insurance policy in 1986 which paid 10% interest in the early years. Twenty years later, she received notice that the policy will soon terminate unless a much-higher premium is paid because of falling interest rates. This type of policy is known as a(n):",o:["Whole Life policy","Variable Life policy","Universal life policy","Indexed Universal Life"],a:2,e:"Universal Life policies are interest-sensitive. If projected interest rates fall short, the policy can lapse unless additional premiums are paid."},
{c:"Retirement",q:"Rick recently died and left behind an individual IRA account in his name. His widow was forwarded the balance of the IRA. The widow qualifies for the:",o:["10% penalty exemption","1035 exchange","Marital deduction","Step-up in basis"],a:2,e:"A surviving spouse who inherits an IRA qualifies for the unlimited marital deduction, allowing tax-free transfer."},
{c:"Retirement",q:"Which of these is NOT considered to be a cost connected with an individual's death?",o:["Funeral expenses","Estate settlement costs","Business expenses","Medical bills"],a:2,e:"Business expenses are not a personal death cost — they are business obligations, not connected to an individual's personal death costs."},
{c:"Policy Types",q:"A life policy with a death benefit and cash value that can fluctuate according to the performance of its underlying investment portfolio is referred to as:",o:["Indexed Universal Life","Universal Life","Variable Life","Whole Life"],a:2,e:"Variable Life has a fixed premium but both cash value and death benefit fluctuate based on separate account (investment) performance."},
{c:"Contracts",q:"Which of the following consists of an offer, acceptance, and consideration?",o:["Binder","Receipt","Contract","Application"],a:2,e:"A valid contract requires offer, acceptance, and consideration. In insurance, the application is the offer, approval is acceptance, and the premium is consideration."},
{c:"Contracts",q:"The Consideration clause in a life insurance contract contains what pertinent information?",o:["The death benefit amount","The beneficiary's rights","Amount of premium payments and when they are due","The underwriting guidelines"],a:2,e:"The Consideration clause specifies the premium amount and payment schedule — what the policyowner gives in exchange for coverage."},
{c:"Underwriting",q:"At what time must a policyowner have insurable interest on the insured in order for the life policy to be valid?",o:["At the time of claim","At the time of death","At the time of application","At all times"],a:2,e:"Insurable interest must exist at the inception (application) of the life insurance contract. It need not continue after that."},
{c:"Provisions",q:"Which type of life insurance beneficiary requires his/her consent when a change of beneficiary is attempted by the policyowner?",o:["Revocable beneficiary","Contingent beneficiary","Irrevocable beneficiary","Primary beneficiary"],a:2,e:"An irrevocable beneficiary designation cannot be changed without that beneficiary's written consent."},
{c:"Provisions",q:"How would a contingent beneficiary receive the policy proceeds in an AD&D policy?",o:["Automatically when the policy matures","If the primary beneficiary dies before the insured","Only if no primary beneficiary is named","At the policyowner's request"],a:1,e:"The contingent (secondary) beneficiary receives proceeds only if the primary beneficiary predeceases the insured."},
{c:"Provisions",q:"P is blinded in an industrial accident. Which provision of his life insurance policy will pay a stated benefit amount?",o:["Waiver of premium rider","Accelerated death benefit","Accidental Death and Dismemberment clause","Long-term care rider"],a:2,e:"An AD&D rider pays for accidental loss of sight, limbs, or life. Blindness qualifies as a dismemberment benefit."},
{c:"Retirement",q:"A sole proprietor may use this plan ONLY if the employees of this business are included:",o:["SIMPLE IRA","SEP-IRA","Keogh Pension Plan","401(k)"],a:2,e:"A Keogh (HR-10) plan is available to self-employed individuals but must include all eligible employees — not just the owner."},
{c:"Policy Types",q:"Which of the following actions require a policyowner to provide proof of insurability in an Adjustable Life policy?",o:["Decrease face amount","Increase premium","Increase face amount","Change beneficiary"],a:2,e:"Increasing the face amount (death benefit) in an Adjustable Life policy requires proof of insurability since more risk is added."},
{c:"Policy Types",q:"Which of these is an element of a Variable Life policy?",o:["Flexible premium","No death benefit guarantee","A fixed, level premium","Guaranteed cash value"],a:2,e:"Variable Life has a FIXED premium. The cash value and death benefit fluctuate. A minimum death benefit is guaranteed."},
{c:"Provisions",q:"T took out a $50,000 life insurance policy with an Accidental Death and Dismemberment rider. Five years later, T commits suicide. How much will the insurer pay?",o:["$0","$100,000","$50,000","Premiums paid only"],a:2,e:"After 2 years, the suicide exclusion expires and the death benefit is payable. The AD&D rider does not cover suicide, so only the base $50,000 is paid."},
{c:"Provisions",q:"How do life insurance companies handle cases where the insured commits suicide within the contract's stated contestable period?",o:["Pay full death benefit","Pay reduced benefit","Claims are denied under the Suicide clause of the policy","Refund premiums plus interest"],a:2,e:"If suicide occurs within 2 years of policy issue, the insurer denies the claim under the suicide clause and returns premiums paid only."},
{c:"Retirement",q:"Premature IRA distributions are assessed a penalty tax of:",o:["5%","20%","10%","15%"],a:2,e:"Distributions from traditional IRAs before age 59½ incur a 10% IRS early withdrawal penalty in addition to ordinary income tax."},
{c:"Underwriting",q:"T is given a receipt after completing a life insurance application and paying the initial premium. Under this situation, T's coverage is:",o:["Immediate and unconditional","Conditional, depending on the insurer's underwriting guidelines","Bound regardless of outcome","Delayed until policy delivery"],a:1,e:"A conditional receipt means coverage is effective from the application date only IF the applicant meets the underwriting requirements."},
{c:"Policy Types",q:"A policyowner is able to choose the frequency of premium payments through what policy feature?",o:["Grace period","Automatic premium loan","Premium Mode","Dividend option"],a:2,e:"Premium Mode refers to the frequency of premium payments: annual, semi-annual, quarterly, or monthly."},
{c:"Policy Types",q:"What kind of life insurance product covers children under their parent's policy?",o:["Juvenile whole life","Second-to-die policy","Term rider","GIR rider"],a:2,e:"A children's term rider covers all children under a parent's permanent policy; newborns are automatically covered after a specified period."},
{c:"Provisions",q:"K owns a Whole Life policy. If K wants an increasing Death Benefit to protect against inflation, which Dividend Option should she choose?",o:["Cash","Accumulate at interest","Reduction of premium","Paid-Up Additional Insurance"],a:3,e:"Paid-Up Additions (PUAs) use dividends to purchase additional whole life coverage, increasing both the death benefit and cash value over time."},
{c:"Policy Types",q:"All of these are characteristics of an Adjustable Life policy, EXCEPT:",o:["Premium can be increased or decreased","Face amount can be changed","Coverage can be term or permanent","Face amount can be adjusted using policy dividends"],a:3,e:"Adjustable Life allows changes in premium and face amount, but not through policy dividends — those are separate from the adjustable features."},
{c:"Provisions",q:"N is covered by a Term Life policy and does not make the required premium payment which was due August 1. N died September 15. What action will the insurer take?",o:["Pay full death benefit","Pay reduced death benefit","Claim will be denied","Refund premiums paid"],a:2,e:"The 31-day grace period expired before September 15. The policy lapsed, so the claim is denied."},
{c:"Policy Types",q:"F needs life insurance that provides coverage for only a limited amount of time with a death benefit that changes regularly according to a schedule. What kind of policy is needed?",o:["Level term policy","Whole Life","Decreasing term policy","Universal Life"],a:2,e:"Decreasing term has a death benefit that decreases on a scheduled basis while premiums remain level — ideal for mortgage protection."},
{c:"FL Regulations",q:"What is the purpose of the U.S.A. Patriot Act?",o:["Regulate insurance company solvency","Establish ERISA guidelines","Detect and deter terrorism","Govern consumer credit reporting"],a:2,e:"The USA Patriot Act was enacted after 9/11 to detect and deter terrorism, requiring AML programs in financial institutions including life insurers."},
{c:"Provisions",q:"Which of these actions is taken when a policyowner uses a Life Insurance policy as collateral for a bank loan?",o:["Absolute assignment","Beneficiary change","Collateral assignment","Policy loan"],a:2,e:"Collateral assignment temporarily transfers policy rights to a lender as loan security. Rights revert to the owner when the loan is repaid."},
{c:"Underwriting",q:"The reason for backdating a policy is to:",o:["Extend the free-look period","Avoid contestability","Obtain a premium rate based on an earlier age","Start coverage sooner"],a:2,e:"Policies can be backdated up to 6 months in FL to 'save age' — locking in a lower premium rate based on a younger age."},
{c:"Provisions",q:"S has a Whole Life policy with a premium payment due soon. Which provision would keep the policy in force if S does not make the required payment and the policy has adequate cash value?",o:["Grace period","Extended term","Automatic Policy Loan","Reduced paid-up"],a:2,e:"The Automatic Premium Loan (APL) provision automatically borrows from available cash value to pay an overdue premium, preventing lapse."},
{c:"Provisions",q:"The free-look provision begins upon:",o:["Policy issue date","Application date","Receipt of the policy by the policyowner","First premium payment"],a:2,e:"The free-look period starts when the policyowner receives the policy, giving them 14 days (21 if replacing) to return it for a full refund."},
{c:"Contracts",q:"At what point does an informal agreement become a binding contract?",o:["When an agent signs","When the application is submitted","When consideration is provided by one of the parties to the contract","When the policy is delivered"],a:2,e:"A contract becomes binding when consideration (premium payment or promise to pay) is provided."},
{c:"Policy Types",q:"K buys a policy where the premium stays fixed for the first 5 years. The premium then increases in year 6 and stays level thereafter, with the death benefit remaining the same. What kind of policy is this?",o:["Graded Premium Whole Life","Modified Whole Life","Universal Life","Variable Life"],a:1,e:"Modified Whole Life features a lower premium in the early years that increases at a set point and then remains level — different from standard straight life."},
{c:"Contracts",q:"What does the insurance agreement in a Life insurance contract establish?",o:["The premium payment schedule","The beneficiary's rights","An insurer's basic promise","The underwriting criteria"],a:2,e:"The insuring clause establishes the insurer's fundamental promise to pay the death benefit upon the insured's death."},
{c:"Contracts",q:"In an insurance contract, the insurer is the only party who makes a legally enforceable promise. What kind of contract is this?",o:["Bilateral","Adhesion","Aleatory","Unilateral"],a:3,e:"A unilateral contract means only one party (the insurer) makes a legally enforceable promise. The policyowner can stop paying without legal penalty."},
{c:"Policy Types",q:"Which of the following information is NOT required to be included in a Whole Life policy?",o:["Premium amounts","Grace period provision","Nonforfeiture options","Policy's guaranteed dividend table"],a:3,e:"Dividends are not guaranteed in any policy and therefore a guaranteed dividend table is not a required policy provision."},
{c:"Policy Types",q:"Which of the following types of policies pays a benefit if the insured goes blind?",o:["Waiver of premium","Long-term care","AD&D","Accelerated death benefit"],a:2,e:"Accidental Death and Dismemberment (AD&D) pays for loss of sight, limbs, or life due to a covered accident."},
{c:"Policy Types",q:"Term Life Policies that have the ability to be converted to permanent coverage may do so during a specific time period. This conversion period varies according to:",o:["The insured's age","State law","The contract","The insurer's discretion"],a:2,e:"The conversion period for term policies is specified in the contract itself and varies by policy."},
{c:"Provisions",q:"A father who dies within 3 years after purchasing a life insurance policy on his infant daughter can have the policy premiums waived under which provision?",o:["Waiver of premium rider","GIR rider","Payor provision","Accidental death rider"],a:2,e:"The Payor Provision waives premiums if the payor (typically a parent) dies or becomes disabled before the insured child reaches a specified age."},
{c:"Contracts",q:"Which of the following BEST describes a warranty?",o:["Statement believed to be true","Statement guaranteed to be true","A policy provision","An underwriting requirement"],a:1,e:"A warranty is a statement guaranteed to be absolutely true, as opposed to a representation which is only believed to be true."},
{c:"Policy Types",q:"What advantage does the renewability feature give to a term policy?",o:["Adds cash value","Lowers the premium at renewal","The insured may extend the coverage period","Converts to whole life automatically"],a:2,e:"The renewability feature allows the insured to renew term coverage at expiration without evidence of insurability, extending the coverage period."},
{c:"Policy Types",q:"Which of these types of life insurance allows the policyowner to have level premiums and to also choose from a selection of investment options?",o:["Universal Life","Indexed Universal Life","Variable Life","Whole Life"],a:2,e:"Variable Life has a fixed (level) premium and allows the policyowner to direct cash value into investment sub-accounts (separate accounts)."},
{c:"Provisions",q:"Which of the following provisions guarantees that premiums will be waived if a Juvenile Life policyowner becomes disabled?",o:["Waiver of premium rider","GIR rider","Payor clause","Disability income rider"],a:2,e:"The Payor Clause (Payor Provision) waives premiums on a juvenile policy if the adult policyowner/payor becomes disabled or dies."},
{c:"Contracts",q:"When must insurable interest exist for a life insurance contract to be valid?",o:["At the time of claim","At the time of death","Inception of the contract","At all times"],a:2,e:"Insurable interest must exist at the inception (start) of the life insurance contract — not necessarily at the time of death."},
{c:"Policy Types",q:"A level premium indicates:",o:["The premium equals the death benefit","The premium is fixed for the entire duration of the contract","The premium decreases over time","The premium adjusts annually"],a:1,e:"A level premium remains fixed and unchanged for the entire life of the policy."},
{c:"Policy Types",q:"When an employee is terminated, which statement about a group term life conversion is true?",o:["Coverage ends immediately","The employee must provide evidence of insurability","Policy proceeds will be paid if the employee dies during the conversion period","The employer must continue coverage for 6 months"],a:2,e:"During the 31-day conversion period after termination, the group coverage remains in effect. If the employee dies during this period, the claim is paid."},
{c:"Underwriting",q:"Statements made on an insurance application that are believed to be true to the best of the applicant's knowledge are called:",o:["Warranties","Guarantees","Representations","Binders"],a:2,e:"Representations are statements believed to be true — not guaranteed. Warranties are guaranteed to be true."},
{c:"Policy Types",q:"Which provision is NOT a requirement in a group life policy?",o:["Grace period","Conversion privilege","Incontestability clause","Accidental death provision"],a:3,e:"The Accidental Death and Dismemberment provision is optional in group life policies, not a standard required provision."},
{c:"Contracts",q:"What is the consideration given by an insurer in the Consideration clause of a life policy?",o:["The application","The premium","Promise to pay a death benefit to a named beneficiary","The policy itself"],a:2,e:"The insurer's consideration is the promise to pay the death benefit — in exchange for the policyowner's premium payments."},
{c:"Underwriting",q:"When third-party ownership is involved, applicants who also happen to be the stated primary beneficiary are required to have:",o:["An insurable interest in the proposed insured","Written consent of the insured","A minimum policy amount","A co-signer"],a:0,e:"Third-party owners who are also beneficiaries must have insurable interest in the proposed insured at the time of application."},
{c:"Annuities",q:"An individual who purchases a Life annuity is given protection against:",o:["Premature death","Market risk","The risk of living longer than expected","Inflation"],a:2,e:"A life annuity guarantees income for life, protecting against longevity risk — the risk of outliving your assets."},
{c:"Annuities",q:"T has an annuity that guarantees an income payment for the rest of his life. The contract also guarantees that if T dies before receiving payments for 20 years, the remaining payments will be paid to his son for the balance of the 20 years. What type of annuity is this?",o:["Straight Life annuity","Joint and Survivor annuity","Life Annuity with Period Certain","Fixed Period annuity"],a:2,e:"Life Annuity with Period Certain pays for life but guarantees a minimum period (here 20 years). If the annuitant dies early, the beneficiary gets the remaining period payments."},
{c:"Annuities",q:"The payments on Q's annuity are no less than $250 quarterly. Which of the following annuities does Q own?",o:["Single Premium Immediate","Straight Life annuity","Flexible Installment Deferred","Variable annuity"],a:2,e:"A Flexible Installment Deferred annuity accepts multiple varying contributions over time — matching the pattern of recurring $250 quarterly payments."},
{c:"Annuities",q:"Which type of contract liquidates an estate through recurrent payments?",o:["Whole Life","Term Life","Annuity","Buy-sell agreement"],a:2,e:"An annuity liquidates (distributes) an estate through periodic income payments — the opposite purpose of life insurance."},
{c:"Annuities",q:"The type of annuity that can be purchased with one monetary deposit is called a(n):",o:["Flexible premium annuity","Deferred annuity","Single Premium annuity","Variable annuity"],a:2,e:"A Single Premium Annuity is funded with one lump-sum payment, either as an immediate or deferred annuity."},
{c:"Annuities",q:"Which of the following are Equity Indexed annuities typically invested in?",o:["Corporate bonds","Real estate","S&P 500","Money market funds"],a:2,e:"Equity Indexed (or Fixed Indexed) Annuities are benchmarked to a stock market index, most commonly the S&P 500."},
{c:"Annuities",q:"Which of the following is NOT included in an annuity contract?",o:["Surrender charge provision","Free-look period","Annuitization options","AD&D rider"],a:3,e:"AD&D riders are life insurance provisions — annuity contracts do not include accidental death and dismemberment benefits."},
{c:"Annuities",q:"Which of the following statements concerning an Individual Straight Life annuity is accurate?",o:["Payments stop after a period certain","Payments are made to an annuitant for life","Payments continue to a beneficiary after death","Payments are guaranteed for 20 years"],a:1,e:"A Straight Life annuity pays income for the annuitant's entire lifetime only — payments stop at death with no residual value to beneficiaries."},
{c:"Policy Types",q:"Which of the following statements about noncontributory employee group life insurance is FALSE?",o:["The employer pays the entire premium","No employee contribution is required","100% participation is required","A minimum number of employees is required to participate"],a:3,e:"Noncontributory group plans require 100% participation but there is no specific minimum number of employees required by most group life rules."},
{c:"Annuities",q:"What is considered to be a characteristic of an immediate annuity?",o:["It has a long accumulation phase","Funded with flexible premiums","Benefit payments start within one payment period of purchase","It invests in separate accounts"],a:2,e:"An immediate annuity begins payments within one payment period (typically within 12 months) of the single premium purchase."},
{c:"FL Regulations",q:"Every resident agent must have and maintain at their place of business the usual and customary records pertaining to transactions under their license for at least how long?",o:["2 years","3 years","5 years","7 years"],a:2,e:"Florida requires insurance agents to maintain transaction records for at least 5 years."},
{c:"FL Regulations",q:"How can an agent-in-charge have more than one location?",o:["By getting a second license","By written approval from the DFS","Only if the agent-in-charge is present when insurance activity occurs","With 30 days' notice to DFS"],a:2,e:"An agent-in-charge may oversee multiple locations only if they are physically present at each location when insurance activity is being conducted."},
{c:"Unfair Practices",q:"Which Unfair Trade Practice involves an agent suggesting that an insurance policy is like a share of stock?",o:["Twisting","Defamation","Rebating","Misrepresentation"],a:3,e:"Comparing a life insurance policy to a stock or investment security without proper disclosure is misrepresentation."},
{c:"FL Regulations",q:"A licensed agent must be appointed by an insurance company to solicit insurance in Florida. The agent's license will terminate if a certain period of time elapses without being appointed. How long is this period of time?",o:["12 months","24 months","36 months","48 months"],a:3,e:"In Florida, a license will terminate if the agent goes 48 months (4 years) without being appointed by an insurer."},
{c:"Unfair Practices",q:"Which Unfair Trade Practice involves an agent telling a prospective client that a policy's dividends are guaranteed?",o:["Twisting","Churning","Rebating","Misrepresentation"],a:3,e:"Representing dividends as guaranteed when they are not is misrepresentation, since dividends are not guaranteed policy provisions."},
{c:"FL Regulations",q:"According to Florida's life insurance replacement laws, a policyowner must be provided with a written Comparison and Summary Statement:",o:["In all replacement situations","When it's requested by the policyowner","Only when replacing a variable policy","Only when premiums increase"],a:1,e:"The written comparison and summary statement is required to be provided when the policyowner requests it during a replacement transaction."},
{c:"FL Regulations",q:"All of the following will result in the suspension of an agent's license EXCEPT:",o:["Writing controlled business exclusively","Committing fraud","Misappropriating client funds","Acting with fiduciary responsibility"],a:3,e:"Acting with fiduciary responsibility is a legal requirement — it does not result in suspension. All other choices are grounds for discipline."},
{c:"FL Regulations",q:"Group Life policies in Florida are required to contain a conversion privilege that allows for conversion to an individual policy for a stated period of time. That period is:",o:["14 days","21 days","31 days","60 days"],a:2,e:"Florida group life policies must include a 31-day conversion privilege allowing terminated employees to convert to individual coverage."},
{c:"Unfair Practices",q:"An agent who makes misleading statements that lead to the termination of an existing insurance policy so that a new policy with another insurer can be taken out has committed:",o:["Churning","Rebating","Twisting","Misrepresentation"],a:2,e:"Twisting is using misrepresentation to induce a policyholder to replace an existing policy with one from a different insurer."},
{c:"FL Regulations",q:"In order for a domestic, foreign, or alien insurance company to conduct business, it must be authorized by whom?",o:["The federal government","NAIC","The state where they are conducting business","The SEC"],a:2,e:"All insurers — domestic, foreign, or alien — must be licensed and authorized by the state in which they want to conduct business."},
{c:"FL Regulations",q:"Nonprofit life insurance providers that are covered by a special section in the Florida insurance code are called:",o:["Reciprocal insurers","Lloyd's associations","Fraternal life insurance organizations","Mutual benefit associations"],a:2,e:"Fraternal benefit societies are nonprofit organizations providing insurance to members; they have their own section of the FL insurance code."},
{c:"FL Regulations",q:"The Bureau of Unclaimed Property is overseen by the:",o:["Insurance Commissioner","Attorney General","Chief Financial Officer","Governor"],a:2,e:"The Bureau of Unclaimed Property operates under the Florida Chief Financial Officer (CFO) and the Department of Financial Services."},
{c:"FL Regulations",q:"What is the main reason for regulating the insurance industry?",o:["Protect agent commissions","Maintain the solvency of insurance companies","Prevent competition","Standardize policy language"],a:1,e:"The primary purpose of insurance regulation is to maintain insurer solvency, ensuring companies can pay claims to policyholders."},
{c:"Business Insurance",q:"Two partners own equal shares in a business worth a total of $1,000,000. If they both commit to the purchase of a life insurance policy that will fund a Buy-Sell Agreement, which of the following is TRUE?",o:["The business owns a $1,000,000 policy on each partner","Each partner owns a $1,000,000 policy on their own life","Each partner owns a $500,000 policy on their partner's life","The business owns a $500,000 policy on each partner"],a:2,e:"In a cross-purchase buy-sell with equal partners, each partner owns a policy on the other equal to their share value ($500,000 each)."},
{c:"Business Insurance",q:"What is considered a valid reason for small businesses to insure the lives of its major shareholders?",o:["To pay the shareholders' personal debts","To fund a buy-sell agreement","To pay dividends to other shareholders","To provide life insurance benefits to employees"],a:1,e:"Funding a buy-sell agreement is a primary legitimate business purpose for insuring major shareholders' lives."},
{c:"Retirement",q:"One becomes eligible for Social Security disability benefits after having been disabled for:",o:["1 month","3 months","5 months","12 months"],a:2,e:"Social Security disability has a 5-month waiting (elimination) period before benefits begin."},
{c:"Underwriting",q:"Consumer reports requested by an underwriter during the application process of a life insurance policy can be used to determine:",o:["Medical history","Criminal background","Probability of making timely premium payments","Family history"],a:2,e:"Consumer credit reports help underwriters assess financial reliability, including the likelihood of timely premium payments."},
{c:"Retirement",q:"In a qualified retirement plan, the yearly contributions to an employee's account:",o:["Are unlimited","Are not regulated","Are restricted to maximum levels set by the IRS","Must equal the employer's contribution"],a:2,e:"The IRS sets annual contribution limits for qualified retirement plans such as 401(k)s, IRAs, and SEPs."},
{c:"Policy Types",q:"What type of life insurance are credit policies issued as?",o:["Whole Life","Universal Life","Term","Variable Life"],a:2,e:"Credit life insurance is issued as decreasing term insurance, with the benefit decreasing as the loan balance is paid down."},
{c:"Policy Types",q:"Which type of policy is considered to be overfunded, as stated by IRS guidelines?",o:["Variable Universal Life","Indexed Universal Life","Straight Whole Life","Modified Endowment Contract"],a:3,e:"A MEC is a life policy that has been overfunded beyond the 7-pay test limits set by the IRS."},
{c:"Annuities",q:"When is the face amount paid under a Joint Life and Survivor policy?",o:["Upon the first death","When both are disabled","Upon death of the last insured","At policy maturity"],a:2,e:"A Joint Life and Survivor (Second-to-Die) policy pays the face amount only after the death of the last surviving insured."},
{c:"Underwriting",q:"A statement made by an insured in an insurance application that must be true to the best of one's knowledge and which becomes a part of the contract is known as:",o:["A warranty","A guarantee","A binder","A representation"],a:3,e:"Representations are statements believed to be true to the best of the applicant's knowledge — they become part of the contract when the application is attached."},
{c:"Policy Types",q:"Which of the following actions is NOT possible with a Universal Life policy?",o:["Adjusting the death benefit","Changing premium amounts","Skipping a premium payment","Premiums may be applied as a credit against income tax"],a:3,e:"Universal Life premiums are NOT tax-deductible or creditable against income tax. UL does allow premium and death benefit flexibility."},
{c:"Policy Types",q:"Q is looking to buy a life insurance policy that will provide the greatest amount of protection for a temporary time period. Which of these policies should Q purchase?",o:["Whole Life","Universal Life","Term life","Variable Life"],a:2,e:"Term life provides the greatest death benefit for the lowest premium for a temporary (specific) period."},
{c:"Underwriting",q:"The underwriting process involves all of these, EXCEPT for:",o:["Reviewing the application","Ordering an APS","Classifying the risk","Policy loan"],a:3,e:"Policy loans are a post-issue policyowner right — they have nothing to do with the underwriting process."},
{c:"Retirement",q:"In an individual retirement account (IRA), rollover contributions are:",o:["Limited to $6,000 per year","Not limited by dollar amount","Subject to 20% withholding","Only allowed once every 5 years"],a:1,e:"IRA rollover contributions from a qualified plan are NOT limited by dollar amount — the entire distribution can be rolled over."},
{c:"Provisions",q:"Which provision prevents an insurer from changing the terms of the contract with the policyowner by referring to documents not found within the policy itself?",o:["Grace period","Incontestability clause","Entire Contract Provision","Assignment provision"],a:2,e:"The Entire Contract Provision states that the policy and attached application constitute the entire contract — no outside documents can modify it."},
{c:"Retirement",q:"Post-tax dollar contributions are found in:",o:["Traditional IRA investments","401(k) plans","Roth IRA investments","SEP-IRA plans"],a:2,e:"Roth IRA contributions are made with after-tax (post-tax) dollars, which is why qualified distributions are tax-free."},
{c:"Policy Types",q:"An insurer may normally delay the payment of a cash value loan or surrender value for up to:",o:["30 days","3 months","6 months","1 year"],a:2,e:"Insurers may legally delay payment of cash value loans or surrender values for up to 6 months (except for premium payment purposes)."},
{c:"Policy Types",q:"How does a typical Variable Life Policy investment account grow?",o:["Through fixed interest guaranteed by the insurer","Through mutual funds, stocks, bonds","Through money market accounts only","Through the insurer's general account"],a:1,e:"Variable Life cash value is invested in separate accounts consisting of mutual funds, stocks, bonds, and other securities. Returns are not guaranteed."},
{c:"Provisions",q:"A policy loan is made possible by which of these life insurance policy features?",o:["Grace period","Incontestability clause","Cash value provision","Conversion privilege"],a:2,e:"Policy loans are available only because permanent policies build cash value. The cash value provision enables borrowing against it."},
{c:"Provisions",q:"A Cost of Living rider gives the insured:",o:["A reduced premium","Waiver of premiums at retirement","Additional death benefits","A return of premium"],a:2,e:"A Cost of Living (COL) rider increases the death benefit periodically (tied to CPI) to help keep pace with inflation."},
{c:"Underwriting",q:"P is a producer who notices 5 questions on a life application were not answered. What actions should P take?",o:["Submit the application as-is","Leave blanks — insurer will fill them in","Set up a meeting with the applicant to answer the remaining questions","Return the application to the insurer"],a:2,e:"The producer must ensure the application is complete. They should meet with the applicant to complete the unanswered questions before submission."},
{c:"Provisions",q:"All of these statements concerning Settlement Options are true, EXCEPT:",o:["The beneficiary may select a settlement option","The policyowner may pre-select a settlement option","Interest earned under settlement options is taxable","Only the beneficiary may select"],a:3,e:"Both the policyowner AND the beneficiary can select settlement options — it is not exclusive to the beneficiary."},
{c:"Underwriting",q:"A $20,000 life insurance policy application is completed; however the producer does not collect the initial premium. At what point does the coverage go into effect?",o:["When the application is submitted","When the insurer approves the application","When the applicant receives the policy and pays the initial premium","After the free-look period"],a:2,e:"Without initial premium at application, coverage begins when the policyowner receives the policy AND pays the initial premium."},
{c:"Policy Types",q:"Which of the following Life insurance policies combine term insurance with an investment element?",o:["Whole Life","Variable Life","Universal Life","Decreasing Term"],a:2,e:"Universal Life combines a term insurance element (cost of insurance) with a savings/investment element (cash value earning interest)."},
{c:"Retirement",q:"Traditional individual retirement annuity (IRA) distributions must start by:",o:["Age 70½","Age 72","April 1st of the year following the year the participant attains age 73","December 31 of the year the participant turns 73"],a:2,e:"Current law (SECURE 2.0) requires RMDs to begin by April 1 of the year following the year the participant turns age 73."},
{c:"Underwriting",q:"Upon policy delivery, a signed good health statement is requested from the applicant. Why would this be necessary?",o:["Required by Florida law for all policies","The insured's health may have changed since the medical exam","The initial premium was NOT submitted with the application","The free-look period requires it"],a:2,e:"If the initial premium was not paid with the application, the agent must collect it at delivery and obtain a good health statement confirming no adverse health changes."},
{c:"Provisions",q:"B owns a Whole Life policy with a guaranteed insurability option that allows him to purchase, without evidence of insurability, stated amounts of additional Whole Life coverage at specified times. This is the definition of:",o:["Waiver of premium rider","Accelerated death benefit","Guaranteed Insurability Rider (GIR)","Payor provision"],a:2,e:"The GIR guarantees the right to purchase additional coverage at specified option dates without providing evidence of insurability."},
{c:"Business Insurance",q:"Company Z has a Cross Purchase Buy-Sell Agreement in place among its three founding partners. If the agreement is funded with individual life insurance, what would it require?",o:["The company owns one policy on each partner","Each partner owns one policy on themselves","Each partner must own a policy on the other partners","A trust owns all policies"],a:2,e:"In a cross-purchase agreement with 3 partners, each partner owns policies on the other 2 partners — requiring 6 total policies."},
{c:"Policy Types",q:"Life insurance immediately creates an estate upon the death of an insured. Which of the following policies is characterized by a guaranteed minimum death benefit?",o:["Universal Life","Variable Universal Life","Variable life","Indexed Universal Life"],a:2,e:"Variable Life guarantees a minimum death benefit even if the separate account investments perform poorly. VUL does not guarantee a minimum death benefit."},
{c:"Policy Types",q:"P is looking to purchase a life insurance policy that will pay a stated monthly income to his beneficiaries for 20 years after he dies and a lump sum of $20,000 at the end of that 20-year period. What type of policy should P purchase?",o:["Family Income Policy","Endowment policy","Family Maintenance policy","Decreasing term policy"],a:2,e:"A Family Maintenance Policy pays a monthly income for a stated period from the date of death, plus the face amount (lump sum) at the end of the period."},
{c:"Provisions",q:"J let her life insurance policy lapse 8 months ago due to nonpayment. She can reestablish coverage under which of the following provisions?",o:["Grace period","Automatic premium loan","Nonforfeiture option","Reinstatement provision"],a:3,e:"The Reinstatement Provision allows a lapsed policy to be reinstated within 3 years with proof of insurability and payment of back premiums plus interest."},
{c:"Policy Types",q:"A life policy that contains a monthly mortality charge as well as self-directed investment choices is called a(n):",o:["Universal Life policy","Variable Life policy","Variable Universal Life policy","Indexed Universal Life policy"],a:2,e:"Variable Universal Life (VUL) has a monthly mortality charge (cost of insurance) plus self-directed investment options in separate accounts."},
{c:"Policy Types",q:"S, age 40, is looking to buy a Life Insurance policy that will allow for increases or decreases in coverage as his needs change. The policy best suited for S would be:",o:["Whole Life","Term Life","Universal Life","Variable Life"],a:2,e:"Universal Life's flexible premium and adjustable death benefit make it ideal for someone who needs coverage that can increase or decrease over time."},
{c:"Business Insurance",q:"A company that owns a life insurance policy on one of its key employees may do all of the following EXCEPT:",o:["Change the beneficiary","Take a policy loan","Surrender the policy","Change the policy's interest rate"],a:3,e:"The policyowner (company) can change beneficiaries, take loans, or surrender — but cannot change the interest rate, which is set by the insurer."},
{c:"Underwriting",q:"Which of the following actions should a producer take when submitting an insurance application to an insurer?",o:["Submit only what the applicant filled out","Omit sensitive health information","Inform insurer of relevant information not included on the application","Complete blank answers with best guesses"],a:2,e:"Producers have a duty to disclose to the insurer any material information they are aware of, even if not on the application."},
{c:"Provisions",q:"The Accelerated Death Benefit provision in a life insurance policy is also known as a(n):",o:["Waiver rider","Disability rider","Living Benefit","Survivor benefit"],a:2,e:"The Accelerated Death Benefit is called a Living Benefit because it allows the terminally ill insured to access part of the death benefit while still alive."},
{c:"Provisions",q:"L takes out a life insurance policy and dies 10 years later. During the claim process, the insurer discovers that L had understated her age on the application. Under the Misstatement of Age provision, the insurer will:",o:["Void the policy","Pay full death benefit","Deny the claim","Adjust the death benefit to a reduced amount"],a:3,e:"Under the Misstatement of Age provision, the insurer adjusts the death benefit to what the premium would have purchased at the correct age."},
{c:"Policy Types",q:"Under a Graded Premium Whole Life policy, the premium:",o:["Decreases each year","Stays level throughout","Increases each year during the early years of the contract and remains the same after that time","Fluctuates with interest rates"],a:2,e:"Graded Premium Whole Life starts with lower premiums that increase annually during the early years, then level off permanently."},
{c:"Provisions",q:"M had an annual life insurance premium payment due January 1. She died January 10 without making the premium payment. What action will the insurer take?",o:["Deny the claim — policy lapsed","Pay full face amount","Pay face amount minus the past due premium","Pay reduced death benefit"],a:2,e:"The policy is within the 31-day grace period (January 1 + 31 days). The policy is still in force; the insurer pays the face amount minus the overdue premium."},
{c:"Annuities",q:"Which settlement option pays a stated amount to an annuitant, but no residual value to a beneficiary?",o:["Fixed Period","Fixed Amount","Life Income","Life with Period Certain"],a:2,e:"Straight Life Income pays for the annuitant's lifetime only — there is no residual or refund to a beneficiary after death."},
{c:"Contracts",q:"Insurance policies are considered aleatory contracts because:",o:["Only the insurer makes promises","The contract cannot be negotiated","Performance is conditioned upon a future occurrence","Both parties give equal value"],a:2,e:"Aleatory contracts involve unequal exchanges where performance depends on a future uncertain event (the insured's death or loss)."},
{c:"Provisions",q:"The incontestable clause allows an insurer to:",o:["Contest a claim at any time","Never contest any claim","Contest a claim during the Contestable Period","Void a policy after 5 years"],a:2,e:"The incontestability clause allows the insurer to contest misrepresentations DURING the 2-year contestable period only — not after."},
{c:"Provisions",q:"Who has the right to change a revocable beneficiary?",o:["The beneficiary","The insured","Policyowner","Both the policyowner and beneficiary together"],a:2,e:"The policyowner has the unilateral right to change a revocable beneficiary at any time without the beneficiary's consent."},
{c:"Policy Types",q:"A variable insurance policy:",o:["Guarantees a minimum return on investment accounts","Has fixed premiums and fixed death benefit","Does not guarantee a return on its investment accounts","Is not regulated as a security"],a:2,e:"Variable policies place cash value in separate accounts with market risk — returns are not guaranteed. This is why a securities license is required."},
{c:"Policy Types",q:"All of these statements about Equity Indexed Life Insurance are correct, EXCEPT:",o:["It has a minimum guaranteed interest rate","Gains are capped","Losses are protected by a floor of 0%","The premiums can be lowered or raised, based on investment performance"],a:3,e:"Equity Indexed Life (IUL) has a fixed or flexible premium structure — the premium is not adjusted based on investment performance."},
{c:"Contracts",q:"Life and health insurance policies are:",o:["Bilateral contracts","Aleatory contracts","Unilateral contracts","Negotiated contracts"],a:2,e:"Insurance contracts are unilateral — only the insurer makes a legally enforceable promise. The policyowner can stop paying without legal penalty."},
{c:"Policy Types",q:"Variable Whole Life Insurance can be described as:",o:["A term policy with investment features","A pure investment product","Both an insurance and securities product","A policy with guaranteed cash value"],a:2,e:"Variable Whole Life is both an insurance product (regulated by state insurance departments) and a securities product (regulated by SEC/FINRA)."},
{c:"Policy Types",q:"At what point does a Whole Life Insurance policy endow?",o:["At age 65","At age 70","When the cash value equals the death benefit","When premiums are paid up"],a:2,e:"A Whole Life policy endows at age 100 when the accumulated cash value equals the face amount (death benefit)."},
{c:"Policy Types",q:"A Universal Life policy is sometimes referred to as an unbundled Life Policy because the owner can see the:",o:["Premium mode and payment schedule","Interest earned, cost of insurance, and the expense charges","Death benefit and cash value only","Commission and overhead charges"],a:1,e:"Universal Life is 'unbundled' because the policy statement separately shows the interest credited, cost of insurance (COI), and expense charges."},
{c:"Provisions",q:"A provision in a life insurance policy that pays the policyowner an amount that does not surpass the guaranteed cash value is called the:",o:["Nonforfeiture provision","Dividend provision","Policy Loan provision","Settlement option"],a:2,e:"The Policy Loan provision allows the policyowner to borrow up to the available cash value — the loan cannot exceed the guaranteed cash value."},
{c:"Contracts",q:"When must insurable interest be present in order for a life insurance policy to be valid?",o:["At the time of claim","At the time of death","When the application is made","Throughout the entire policy term"],a:2,e:"Insurable interest must exist at the time the application is made (policy inception). It does not need to continue after that."},
{c:"Policy Types",q:"Which of the following is considered an element of a Variable Life Policy?",o:["Guaranteed cash value","Fixed death benefit","Underlying equity investment","Flexible premium"],a:2,e:"Variable Life uses underlying equity investments in separate accounts. The cash value and death benefit fluctuate based on these investments."},
{c:"Policy Types",q:"Under a Graded Premium policy, the premiums are:",o:["Higher during the policy's early years","Lower during the policy's early years","Fixed throughout","Based on the insured's health"],a:1,e:"Graded Premium Whole Life features lower premiums during the early years that gradually increase before leveling off permanently."},
{c:"Provisions",q:"When a misrepresentation on a life insurance policy application is discovered, what action may an insurance company take?",o:["Void the policy at any time","Void the policy only if it is discovered during the Contestable period and proven to be material","Deny only the current claim","Reduce the death benefit"],a:1,e:"A misrepresentation (non-fraudulent) can only void the policy if discovered DURING the 2-year contestable period AND proven material. Fraud has no time limit."},
{c:"Policy Types",q:"Credit Life insurance is:",o:["A type of whole life insurance","Issued in an amount not to exceed the amount of the loan","Available only to businesses","Issued as permanent coverage"],a:1,e:"Credit life insurance decreasing term coverage is limited to the outstanding loan balance — it cannot exceed the amount of the debt."},
{c:"Policy Types",q:"At the age of 45, an individual withdraws $50,000 from his Qualified Profit-Sharing Plan and deposits this amount into a personal savings account. This action would result in:",o:["Tax-free treatment since it's a rollover","Income tax only — no penalty","Income tax and a 10% penalty assessed upon funds withdrawn from the Qualified Plan","Only a 10% penalty"],a:2,e:"Qualified plan distributions taken before 59½ and not rolled over are subject to ordinary income tax PLUS the 10% early withdrawal penalty."},
{c:"Provisions",q:"M purchased an Accidental Death and Dismemberment (AD&D) policy and named his son as beneficiary. M has the right to change the beneficiary designation at any time. What type of beneficiary is his son?",o:["Irrevocable","Contingent","Revocable","Primary irrevocable"],a:2,e:"Since M can change the beneficiary at any time without consent, the son is a revocable beneficiary."},
{c:"Contracts",q:"Which of these is NOT considered to be an element of an insurance contract?",o:["Offer and acceptance","Consideration","Legal purpose","Negotiating"],a:3,e:"The four elements of an insurance contract are: offer & acceptance, consideration, legal purpose (insurable interest), and competent parties. Negotiating is not an element."},
{c:"Policy Types",q:"N is a student pilot with a large life insurance policy. Which of these features would limit the insurer's obligation in the event N was killed while flying as a student pilot?",o:["Suicide clause","Grace period","Incontestability clause","Exclusion"],a:3,e:"An aviation exclusion rider limits or eliminates the insurer's obligation to pay if the insured dies while operating a non-commercial aircraft."},
{c:"Policy Types",q:"A(n) Variable Life policy offers the owner investment in products such as:",o:["Fixed annuities and CDs","Government bonds only","Money-market funds, long-term bonds and equities","Real estate investment trusts"],a:2,e:"Variable Life separate accounts invest in sub-accounts that may include money market funds, bonds, and equity (stock) funds."},
{c:"Contracts",q:"In a Life insurance contract, an insurance company's promise to pay stated benefits is called the:",o:["Consideration clause","Entire contract clause","Insuring clause","Grace period provision"],a:2,e:"The Insuring Clause is the core promise of the insurance contract — the insurer's promise to pay the death benefit upon the insured's death."},
{c:"Contracts",q:"Which of these require an offer, acceptance, and consideration?",o:["Application","Binder","Receipt","Contract"],a:3,e:"A valid contract requires an offer, acceptance, and consideration. These are the foundational elements of any legally binding agreement."},
{c:"FL Regulations",q:"Which policy requires an agent to register with the National Association of Securities Dealers (NASD) before selling?",o:["Indexed Universal Life","Universal Life","Whole Life","Variable Life"],a:3,e:"Variable Life is a security; agents must register with FINRA (formerly NASD) before selling variable products."},
{c:"Policy Types",q:"Life insurance that covers an insured's whole life with level premiums paid over a limited time is called:",o:["Straight Whole Life","Term Life","Limited Pay Life","Single Premium Life"],a:2,e:"Limited Pay Life covers the insured for their whole life but requires premium payments only for a limited period (e.g. 20 years or to age 65)."},
{c:"Provisions",q:"Which of the following statements is CORRECT about accelerated death benefits?",o:["Available for any illness","Must have a chronic illness to qualify","Must have a terminal illness to qualify","Available only after age 65"],a:2,e:"In Florida, the accelerated death benefit requires the insured to be terminally ill with a life expectancy of 24 months or less."},
{c:"Underwriting",q:"Why must an insurance applicant answer all questions on the application?",o:["It is required by the agent","Statements and representations on the application are part of the consideration for issuing a policy","It speeds up underwriting","It is required by FINRA"],a:1,e:"The application forms part of the contract consideration — the insurer relies on the applicant's answers to assess and price the risk."},
{c:"Retirement",q:"Which of the following is TRUE if the owner of an IRA names their spouse as beneficiary, but then dies before any distributions are made?",o:["The IRA must be distributed immediately","A 10% penalty applies to all funds","The account can be rolled into the surviving spouse's IRA","The funds are taxed as ordinary income immediately"],a:2,e:"A surviving spouse beneficiary can roll an inherited IRA into their own IRA, continuing tax-deferred growth without penalty."},
{c:"Policy Types",q:"What kind of life policy either pays the face value upon the death of the insured or when the insured reaches age 100?",o:["Term Life","Universal Life","Whole Life","Variable Life"],a:2,e:"Whole Life pays the face amount either upon the insured's death OR when the policy endows at age 100 — whichever comes first."},
{c:"Provisions",q:"S buys a $50,000 whole life policy with a $50,000 Accidental Death and Dismemberment rider. S died 1 year later of natural causes. How much will the insurer pay the beneficiary?",o:["$100,000","$25,000","$0","$50,000"],a:3,e:"The AD&D rider only pays for accidental death. Since S died of natural causes, only the base policy ($50,000) is paid."},
{c:"Provisions",q:"Which of these actions is taken when a policyowner uses a Life Insurance policy as collateral for a bank loan?",o:["Absolute assignment","Beneficiary redesignation","Policy loan","Collateral assignment"],a:3,e:"Collateral assignment transfers certain policy rights temporarily to the lender as security for a loan. Rights return to the owner when the loan is repaid."},
{c:"Policy Types",q:"What type of life policy covers two lives and pays the face amount after the first one dies?",o:["Survivorship Life","Second-to-Die","Joint Life Policy","Group Life"],a:2,e:"A Joint Life (First-to-Die) policy covers two insureds and pays the death benefit upon the death of the first insured."},
{c:"Contracts",q:"An insurance contract is considered a policy of adhesion. This means that:",o:["Both parties negotiate the terms","The policyowner writes the contract","The contract can only be modified by the insurer","Either party can change the terms"],a:2,e:"A contract of adhesion is written by one party (the insurer) and accepted or rejected as-is by the other party (applicant). Only the insurer can modify it."},
{c:"Retirement",q:"Tom has a qualified retirement plan with his employer that is currently considered to be 80% 'vested'. How can this be interpreted?",o:["Tom owns 80% of the company's contributions","If Tom's employment is terminated, 20% of the funds would be forfeited","Tom has 80% of the maximum contribution limit","Tom can withdraw 80% without penalty"],a:1,e:"80% vested means Tom owns 80% of employer contributions. If he leaves now, he forfeits the remaining 20%."},
{c:"Policy Types",q:"The investment gains from a Universal Life Policy usually go toward:",o:["The death benefit only","Reducing premiums","The cash value","Paying agent commissions"],a:2,e:"In Universal Life, interest credited on the accumulated premium goes into the cash value, which grows over time."},
{c:"Policy Types",q:"What type of policy would offer a 40-year old the quickest accumulation of cash value?",o:["30-Pay Life","Straight Whole Life","Term Life","20-pay life"],a:3,e:"20-Pay Life concentrates premium payments into 20 years, resulting in faster cash value accumulation compared to Straight Life or 30-Pay Life."},
{c:"Business Insurance",q:"An architecture firm would stand to lose a lot of money in the event of the death of its project manager. Which type of policy should the firm purchase on its project manager?",o:["Group Life","Buy-sell life insurance","Key Person insurance","Split-dollar life insurance"],a:2,e:"Key Person (Key Employee) insurance protects a business from financial loss resulting from the death or disability of a critical employee."},
{c:"Contracts",q:"What provision in a life insurance policy states that the application is considered part of the contract?",o:["Incontestability clause","Grace period provision","Entire Contract provision","Assignment provision"],a:2,e:"The Entire Contract Provision states that the policy AND the attached application together form the entire, complete contract."},
{c:"Policy Types",q:"P owns a $25,000 Life Policy that pays the face amount to him if he lives to age 70, or to his beneficiary if he dies before age 70. What kind of policy does P own?",o:["Whole Life","Term to 70","Endowment at Age 70","Universal Life"],a:2,e:"An Endowment policy pays the face amount either at death (before maturity) or to the policyowner if they survive to the endowment age."},
{c:"Underwriting",q:"A Medical Information Report (MIB) report may disclose which of the following:",o:["Credit score","Criminal history","Prior use of marijuana","Bank account information"],a:2,e:"The MIB collects and shares medical information — including past health conditions, treatments, and lifestyle factors like drug use — among member insurers."},
{c:"Taxation",q:"Which of these statements is INCORRECT regarding the federal income tax treatment of life insurance?",o:["Death benefits paid to a beneficiary are income-tax free","Policy loans are generally not taxable","Dividends are considered a return of premium and generally not taxable","Entire cash surrender value is taxable"],a:3,e:"Only the GAIN (CSV minus total premiums paid) is taxable upon surrender — not the entire cash surrender value."},
{c:"Provisions",q:"If the insured and primary beneficiary are both killed in the same accident and it cannot be determined who died first, where are the death proceeds to be directed under the Uniform Simultaneous Death Act?",o:["Split equally between estates","To the insured's estate","Insured's contingent beneficiary","To the state"],a:2,e:"Under the Uniform Simultaneous Death Act and the Common Disaster clause, if order of death can't be determined, the beneficiary is assumed to have died first — so proceeds go to the insured's contingent beneficiary."},
{c:"Policy Types",q:"S is covered by a whole life policy. Which insurance product can cover his children?",o:["Juvenile whole life policy","Second-to-die policy","Child term rider","Guaranteed insurability rider"],a:2,e:"A child term rider added to a parent's whole life policy covers all children, with newborns automatically covered after a specified waiting period."},
{c:"Policy Types",q:"What kind of premium does a Whole Life policy have?",o:["Increasing","Decreasing","Flexible","Level"],a:3,e:"Whole Life features level premiums — they remain fixed for the entire life of the policy."},
{c:"Policy Types",q:"A student pilot can pay regular premium costs for her life insurance policy with the addition of which of the following?",o:["Extra premium rider","Waiver of premium rider","Aviation exclusion","Disability income rider"],a:2,e:"Adding an aviation exclusion allows the student pilot to pay standard rates — in exchange for excluding coverage for aviation-related deaths."},
{c:"Contracts",q:"Stranger Originated Life Insurance (STOLI) has been found to be in violation of which of the following contractual elements?",o:["Consideration","Competent parties","Legal Purpose (Insurable Interest)","Offer and acceptance"],a:2,e:"STOLI violates the insurable interest requirement — the policy is taken out by a stranger (investor) with no legitimate insurable interest in the insured."},
{c:"Provisions",q:"Which of the following is an example of a nonforfeiture option?",o:["Policy loan","Cash dividend","Reduced Paid-Up option","Waiver of premium"],a:2,e:"Nonforfeiture options include: Cash Surrender Value, Reduced Paid-Up Insurance, and Extended Term Insurance. Reduced Paid-Up is one of the three."},
{c:"Contracts",q:"Which of these arrangements allows one to bypass insurable interest laws?",o:["STOLI","Group Life","Key person insurance","Buy-sell agreement"],a:0,e:"Investor-Originated Life Insurance (IOLI/STOLI) is designed to circumvent insurable interest laws by having strangers fund policies on others' lives."},
{c:"Provisions",q:"A(n) Revocable beneficiary may be changed by the policyowner WITHOUT the consent of the beneficiary. TRUE or FALSE?",o:["False — consent is always required","False — only for term policies","True","True — but only within 2 years"],a:2,e:"TRUE. A revocable beneficiary can be changed by the policyowner at any time, without notifying or getting consent from the beneficiary."},
{c:"Provisions",q:"A life insurance policy which ensures that the premium will be paid if the insured becomes disabled has what kind of rider attached?",o:["Accidental death rider","GIR rider","Payor benefit rider","Waiver of Premium"],a:3,e:"The Waiver of Premium rider waives (pays) the premium if the insured becomes totally and permanently disabled."},
{c:"Contracts",q:"A life insurance policy would be considered a wagering contract WITHOUT:",o:["A named beneficiary","A grace period","Insurable interest","A signed application"],a:2,e:"Without insurable interest, a life insurance policy would be nothing more than a wager (bet) on someone's life — which is why it's a legal requirement."},
{c:"Policy Types",q:"J chooses a monthly premium payment mode on his Whole Life insurance policy. Which of these statements is correct?",o:["The gross premium is lower on a monthly payment mode","Monthly and annual premiums cost the same total","The gross premium is higher on a monthly payment mode as compared to being paid annually","Monthly payments have no additional fees"],a:2,e:"Monthly premium mode has a higher total annual cost due to additional installment processing fees compared to annual payment."},
{c:"Policy Types",q:"Under a trustee group life policy, who would be eligible for a certificate of coverage?",o:["The trustee","The employer","Employee","The beneficiary"],a:2,e:"In a group life policy, individual employees receive a Certificate of Coverage — the master policy is held by the employer or trustee."},
{c:"Provisions",q:"K has a life insurance policy where her husband is beneficiary and her daughter is contingent beneficiary. Under the Common Disaster clause, if K and her husband are both killed in an automobile accident, where would the death proceeds be directed?",o:["Husband's estate","Split between their estates","Daughter","The state"],a:2,e:"Under the Common Disaster clause, if the insured and primary beneficiary die in the same accident, the primary is assumed to have died first — proceeds go to the contingent beneficiary (daughter)."},
{c:"Provisions",q:"E and F are business partners. Each takes out a $500,000 life insurance policy on the other, naming himself as primary beneficiary. E and F eventually terminate their business, and four months later E dies. Although an insurable interest no longer exists, where will the proceeds from E's life insurance policy be directed to?",o:["E's spouse","E's estate","Equally to E's heirs","F"],a:3,e:"Insurable interest only needs to exist at the time of application. Once the policy is in force, the named beneficiary (F) still collects even if the business relationship ended."},
{c:"Contracts",q:"Q purchases a $500,000 life insurance policy and pays $900 in premiums over the first six months. Q dies suddenly and the beneficiary is paid $500,000. This exchange of unequal values reflects which of the following insurance contract features?",o:["Unilateral","Adhesion","Aleatory","Conditional"],a:2,e:"Aleatory contracts involve an exchange of unequal values — a small premium for a potentially large benefit — contingent on a future event."},
{c:"Provisions",q:"J would like to maintain the right to change beneficiaries. Which beneficiary designation should be used?",o:["Irrevocable","Tertiary","Per stirpes","Revocable"],a:3,e:"A revocable beneficiary designation allows the policyowner to change the beneficiary at any time without consent."},
{c:"Provisions",q:"P and Q are married and have three children. P is the primary beneficiary on Q's AD&D policy and Q's sister R is the contingent beneficiary. P, Q, and R are involved in a car accident and Q and R are killed instantly. The Accidental Death benefits will be paid to:",o:["R's estate","Q's estate","Equally to the three children","P only"],a:3,e:"Q (the insured) and R (the contingent beneficiary) both died. P (primary beneficiary) survived, so P collects the full benefit."},
{c:"Provisions",q:"T and S are named co-primary beneficiaries on a $500,000 AD&D policy. Their mother was named contingent beneficiary. Five years later, S dies of natural causes and the father is killed in a scuba accident. How much of the death benefit will the mother receive?",o:["$250,000","$500,000","$0","$100,000"],a:2,e:"T was still alive and is a co-primary beneficiary. Since a primary beneficiary (T) survives, the contingent beneficiary (mother) receives $0. T gets the full $500,000."},
{c:"Underwriting",q:"In regards to representations or warranties, which of these statements is TRUE?",o:["Warranties are believed to be true; representations are guaranteed","If material to the risk, false representations will void a policy","All application statements are warranties","Neither can void a policy"],a:1,e:"A material false representation can void a policy within the contestability period. A warranty is guaranteed true; a representation is believed to be true."},
{c:"Annuities",q:"T, age 70, withdraws cash from a profit-sharing plan and purchases a Straight Life Annuity. What will this transaction provide?",o:["A lump sum at death","Income that can be outlived","Income that cannot be outlived by the owner","A guaranteed 20-year payout"],a:2,e:"A Straight Life Annuity provides income for the annuitant's entire lifetime — it cannot be outlived, regardless of how long the annuitant lives."},
{c:"Annuities",q:"Which of these is an element of a Single Premium annuity?",o:["Flexible contributions","Lump-sum payment","Monthly premium requirement","Separate account investment"],a:1,e:"A Single Premium Annuity is funded with one lump-sum payment at purchase. No further contributions are made."},
{c:"Annuities",q:"P, age 50, purchased an annuity that P will fund with $500/month for 15 years. The annuity will then pay P retirement payments after the 15 years. Which type of annuity did P purchase?",o:["Immediate","Single Premium","Deferred","Variable"],a:2,e:"This is a Flexible Premium Deferred Annuity — contributions are made over time (15 years) during an accumulation phase before payouts begin."},
{c:"Annuities",q:"S recently received a $500,000 lump sum retirement buyout from her employer. She would like to buy an annuity that will immediately furnish her with a guaranteed income for life. What type of annuity is best suited for her situation?",o:["Flexible Premium Deferred","Variable Deferred","Fixed Deferred","Single Premium Immediate"],a:3,e:"A Single Premium Immediate Annuity (SPIA) is funded with one lump sum and begins guaranteed income payments almost immediately — perfect for S's situation."},
{c:"Policy Types",q:"An employee of 20 years recently retired at age 59½. This employee's group life contract can be:",o:["Kept as group coverage at retiree rates","Surrendered for cash value","Converted to an individual permanent policy at an individual rate","Transferred to the new employer"],a:2,e:"Upon retirement or termination, an employee may convert group term life to an individual permanent (whole life) policy within 31 days without evidence of insurability."},
{c:"Annuities",q:"What type of annuity has a cash value that is based upon the performance of its underlying investment funds?",o:["Fixed Annuity","Indexed Annuity","Variable","Immediate"],a:2,e:"Variable Annuities invest in separate accounts (mutual fund-like sub-accounts); the cash value fluctuates based on investment performance."},
{c:"Policy Types",q:"S, while in the process of converting her group life insurance to an individual policy, dies. What happens to the claim her beneficiary submits?",o:["Claim is denied — conversion was incomplete","Only the individual policy pays","Only the group policy pays","Full benefits are payable under the Master contract"],a:3,e:"During the 31-day conversion period, the group coverage remains fully in effect. If the employee dies during this period, the group master contract pays full benefits."},
{c:"Retirement",q:"All of the following statements regarding a Tax Sheltered Annuity (TSA) are true EXCEPT:",o:["Contributions are made pre-tax","It is available to employees of non-profit organizations","Withdrawals before 59½ incur a 10% penalty","Income derived from the TSA is received income tax-free"],a:3,e:"TSA/403(b) plan distributions are taxable as ordinary income when withdrawn — they are NOT received income tax-free. The tax benefit is deferral, not exemption."},
{c:"Annuities",q:"K is an annuitant currently receiving payments. If she were to die before receiving payments equal to the contract value, a beneficiary will continue receiving payments until an amount equal to the contract value has been paid. This is called a(n):",o:["Life with Period Certain","Joint and Survivor","Installment Refund annuity","Fixed Amount annuity"],a:2,e:"An Installment Refund annuity guarantees that if the annuitant dies before receiving the full contract value, the beneficiary receives remaining payments in installments."},
{c:"Underwriting",q:"The minimum age at which a person can sign a life insurance application is:",o:["16 years","18 years","15 years","21 years"],a:2,e:"In Florida, the minimum age to sign a life insurance application is 15 years of age."},
{c:"Underwriting",q:"An applicant who pays the initial premium at the time of application is typically given a(n):",o:["Binding receipt","Policy binder","Conditional receipt","Temporary coverage certificate"],a:2,e:"When the initial premium is submitted with the application, the agent provides a conditional receipt — coverage is effective from the application date if approved."},
{c:"FL Regulations",q:"Which of the following activities will NOT result in the suspension of an agent's license?",o:["Committing fraud","Misappropriating client funds","Working for a foreign insurer","Misrepresentation"],a:2,e:"Working for a foreign (out-of-state) insurer that is licensed/admitted in Florida is perfectly legal and does not result in license suspension."},
{c:"FL Regulations",q:"When replacing or exchanging an annuity, the agent must disclose to the annuitant:",o:["The agent's commission amount","The insurer's profit margin","The possible tax ramifications as a result of the transaction","Nothing — disclosure is optional"],a:2,e:"When replacing an annuity, agents must disclose potential tax consequences (e.g. surrender charges, taxable gains, loss of tax-deferred status)."},
{c:"Unfair Practices",q:"An example of rebating would be:",o:["Replacing a policy with misleading information","Using cash value to fund a new policy","Offering a client something of value not stated in the contract in exchange for their business","Making false statements about a competitor"],a:2,e:"Rebating = offering anything of value (cash, gifts, services) not stated in the policy as an inducement to purchase insurance."},
{c:"FL Regulations",q:"Which of the following areas of state regulation is NOT protected by the savings clause in ERISA?",o:["Insurance","Banking","Securities","Commerce"],a:3,e:"ERISA's savings clause preserves state regulation of insurance, banking, and securities — but 'commerce' is not specifically protected by it."},
{c:"Underwriting",q:"Which of the following documents must an agent submit to the replacing insurance company during the replacement of an existing life insurance policy?",o:["MIB authorization","Copy of the existing policy","Notice to existing and replacing insurers of intention to replace","Attending Physician Statement"],a:2,e:"The agent must provide a Notice of Replacement to both the replacing and existing insurers during a life insurance replacement transaction."},
{c:"Unfair Practices",q:"An example of sliding would be:",o:["Telling a client dividends are guaranteed","Replacing a policy for commissions","Charging for an additional product without the applicant's consent","Offering a rebate to all clients equally"],a:2,e:"Sliding is an unfair practice where an agent adds coverage or products to a policy without the applicant's knowledge or consent, charging them for it."},
{c:"Unfair Practices",q:"An example of unfair discrimination would be:",o:["Charging smokers higher rates","Offering different premiums for individuals of the same risk classification","Charging older applicants more than younger ones","Declining high-risk applicants"],a:1,e:"Unfair discrimination = offering different rates to individuals of the SAME class and SAME risk. Actuarially justified differences (age, health, smoking) are legal."},
{c:"Policy Types",q:"Which of the following employees may NOT be excluded from a group life plan?",o:["Part-time employees working under 20 hours","Probationary employees","Full-time employees after the probationary period","Seasonal employees"],a:2,e:"Full-time employees who have completed the probationary period must be eligible for group life coverage — they cannot be excluded."},
{c:"FL Regulations",q:"An insurance company incorporated under the laws of the state in which its home office is located is called a(n):",o:["Foreign company","Alien company","Admitted company","Domestic company"],a:3,e:"A domestic insurer is incorporated in the state where it maintains its home office and primarily operates."},
{c:"Policy Types",q:"Which of the following is a standard provision of the conversion privileges in a Group Life policy?",o:["Conversion to term insurance only","Conversion at group rates","Group Life coverage can be converted to an individual policy at regular rates on an attained-age basis","Conversion requires evidence of insurability"],a:2,e:"Group life conversion rights allow conversion to individual whole life at the insured's current (attained) age rate, without evidence of insurability, within 31 days."},
{c:"FL Regulations",q:"Any violations of the Florida financial institutions code may be investigated by the:",o:["NAIC","OIR","Department of Financial Services (DFS)","The Governor's office"],a:2,e:"The DFS has authority to investigate violations of the Florida financial institutions code."},
{c:"Unfair Practices",q:"Which of the following is an example of an Unfair Trade Practice?",o:["Charging actuarially justified rates","Offering a buyer's guide","Coercion","Filing policy forms with the state"],a:2,e:"Coercion is an unfair trade practice involving threats or intimidation to force someone to purchase insurance."},
{c:"FL Regulations",q:"Which of the following situations are NOT subject to Florida life insurance laws?",o:["Policy replacement","Agent licensing","Insurance companies' day-to-day operations","Variable product sales"],a:2,e:"Florida insurance laws govern licensing, replacement, and product sales — but internal day-to-day company operations are generally subject to corporate/business law, not insurance law."},
{c:"Unfair Practices",q:"As a condition for a loan, a bank requires the borrower to purchase credit insurance from a specific company. What is the bank guilty of?",o:["Twisting","Rebating","Misrepresentation","Coercion"],a:3,e:"Requiring someone to purchase insurance from a specific company as a loan condition is coercion — an unfair trade practice."},
{c:"FL Regulations",q:"In what year was The Florida Office of Financial Regulation (OFR) created?",o:["1998","2001","2003","2005"],a:2,e:"The Florida Office of Financial Regulation (OFR) was created in 2003."},
{c:"FL Regulations",q:"Which of the following types of insured are life insurance companies allowed to make policy rate discriminations against?",o:["Women vs. men of the same age","People of different races","People that smoke","People of different religions"],a:2,e:"Actuarially justified rate differences are legal. Smokers present a statistically higher mortality risk, so charging them higher rates is permitted."},
{c:"FL Regulations",q:"Which of the following is NOT a legal entity for selling life insurance in Florida?",o:["Domestic insurance company","Foreign insurance company","Fraternal benefit society","Risk management advisers"],a:3,e:"Risk management advisers are not a licensed insurer type. Legal entities for selling life insurance include domestic, foreign, and alien companies, plus fraternal societies."},
{c:"Unfair Practices",q:"Churning can be defined as:",o:["Misrepresenting policy benefits to replace a policy","Using the contract values of an existing policy to purchase a new policy with an existing insurer","Offering gifts to induce a purchase","Making false statements about a competitor"],a:1,e:"Churning specifically involves using an existing policy's own cash value to fund a replacement policy with the same insurer — mainly to generate new commissions."},
{c:"FL Regulations",q:"Which of the following is the best description of 'insurer'?",o:["Only stock insurance companies","Only mutual insurance companies","Any person, corporation, association, or society that writes insurance contracts","Government agencies only"],a:2,e:"An insurer is broadly defined as any entity — person, corporation, association, or society — authorized to write insurance contracts."},
{c:"Unfair Practices",q:"In Florida, deceptive advertising is considered to be a form of:",o:["Twisting","Churning","Misrepresentation","Defamation"],a:2,e:"Deceptive advertising that misleads consumers about insurance products is classified as misrepresentation under Florida's unfair trade practices laws."},
{c:"FL Regulations",q:"In Florida, what is the maximum percentage of controlled business an agent may produce?",o:["25%","50%","75%","100%"],a:1,e:"Florida limits controlled business (insurance on the agent, family, or employer) to no more than 50% of an agent's total business."},
{c:"FL Regulations",q:"A stock insurance company is owned exclusively by its:",o:["Policyholders","The government","Shareholders","Management"],a:2,e:"A stock company is owned by shareholders (stockholders) who invest capital and receive profits in the form of dividends."},
{c:"FL Regulations",q:"According to Florida law, which of the following statements accurately describes an admitted mail order insurance company?",o:["It may operate without a Florida license","It may sell directly without an agent","It may solicit insurance business by mail only with the assistance of a licensed Florida agent","It is not subject to Florida laws"],a:2,e:"Even admitted mail-order insurers must use licensed Florida agents to solicit business — they cannot solicit directly without agent involvement."},
{c:"FL Regulations",q:"According to Florida's rules on disclosure, a life insurance applicant is expected to be provided with a:",o:["MIB authorization only","Prospectus only","Buyer's Guide and Policy Summary","Certificate of insurance"],a:2,e:"Florida requires that life insurance applicants receive both a Buyer's Guide and a Policy Summary at the time of application or before the premium is paid."},
{c:"FL Regulations",q:"Within how many days must a licensee notify the Department of Financial Services of a change in address?",o:["10 days","15 days","30 days","60 days"],a:2,e:"Florida agents must notify the DFS of any change of address within 30 days."},
{c:"FL Regulations",q:"In Florida, which agency is responsible for the rehabilitation or liquidation of insurers?",o:["The OIR","The NAIC","Department of Financial Services (DFS)","The Federal Insurance Office"],a:2,e:"The Florida DFS is responsible for the rehabilitation, liquidation, or conservation of insolvent insurance companies."},
{c:"FL Regulations",q:"In Florida, which of the following is considered an Unfair Trade Practice?",o:["Charging actuarially justified premiums","Filing policy forms","Coercion","Selling variable products with a FINRA license"],a:2,e:"Coercion — using threats or intimidation to force someone to purchase insurance — is an unfair trade practice under Florida law."},
{c:"FL Regulations",q:"Florida's 14-day free-look period for life insurance policies begins at the date of:",o:["Policy issue","Application submission","Delivery","Premium payment"],a:2,e:"The free-look period starts when the policyowner receives (is delivered) the policy — giving them 14 days (21 if replacing) to return it for a full refund."},
{c:"FL Regulations",q:"If an agent would like to sell Variable annuities, which state examination must the agent pass?",o:["Life only","Life and Health","Life and Variable contracts","Health and Variable annuity"],a:2,e:"To sell variable annuities in Florida, an agent must pass the Life and Variable Contracts (2-14) state examination, plus hold a FINRA registration."},
{c:"FL Regulations",q:"In Florida, most life insurance policies have a contestability period of:",o:["1 year","2 years","3 years","5 years"],a:1,e:"Florida life insurance policies have a standard 2-year incontestability period — after which the insurer cannot contest the policy based on misrepresentation."},
{c:"FL Regulations",q:"In Florida, which employee is eligible for an employer's group term life plan?",o:["Part-time employees working under 20 hours per week","Seasonal employees","Employee who works more than 40 hours per week","Contract workers"],a:2,e:"Florida group life plans typically cover full-time employees — commonly defined as those working more than 40 hours per week."},
{c:"FL Regulations",q:"J owns a business and has a Group Life policy covering her employees. J decides to cancel the policy by letting it lapse on the renewal date. What action must be taken?",o:["No notice is required — the policy simply lapses","J must notify only the insurer","All of the employees must be notified of the cancellation either by the insurance company or through J","Only the insurer needs to provide notice"],a:2,e:"Florida requires that all covered employees be notified of group policy cancellation — either directly by the insurer or through the employer."},
{c:"Unfair Practices",q:"J is an agent who has induced an insured through misrepresentation to surrender an existing insurance policy. What is J guilty of?",o:["Churning","Rebating","Twisting","Defamation"],a:2,e:"Twisting is using misrepresentation or misleading information to induce a policyholder to surrender or replace an existing policy."},
{c:"FL Regulations",q:"K is an agent who made an improper sale of an annuity to a client. Which of the following corrective actions would the Department of Financial Services likely order K to take?",o:["Surrender K's license permanently","Require K to retake the state exam","Pay monetary restitution to the client","Revoke K's variable contract license only"],a:2,e:"The DFS may order agents to pay monetary restitution to clients harmed by improper sales practices as a corrective action."},
{c:"Policy Types",q:"K is insured under a Group Life insurance policy. K is considered to be a(n):",o:["Master policyholder","Co-insurer","Certificate holder","Group member policyholder"],a:2,e:"In group life insurance, the employer holds the master policy. Individual employees are certificate holders — they receive certificates of coverage."},
{c:"FL Regulations",q:"The act of an insurance company publishing misleading information about its policy's provisions is called:",o:["Twisting","Defamation","False advertising","Misrepresentation"],a:2,e:"False advertising involves publishing misleading, deceptive, or inaccurate information about insurance policy provisions — an unfair trade practice."},
{c:"Provisions",q:"Which statement regarding third-party ownership of a life insurance policy is true?",o:["It is illegal in Florida","It is only used in personal situations","It is used extensively in estate-planning as well as business circumstances","It requires the insured to be the beneficiary"],a:2,e:"Third-party ownership (where the policyowner, insured, and beneficiary are different parties) is widely used in business and estate planning."},
{c:"Underwriting",q:"When does a life insurance contract become effective if the initial premium is not collected during the application process?",o:["When the application is submitted","When the insurer approves the application","When the free-look period ends","When producer delivers policy and collects initial premium"],a:3,e:"Without the initial premium at application, the policy takes effect when the producer delivers the policy AND collects the first premium from the applicant."},
{c:"Underwriting",q:"Agent J takes an application and initial premium from an applicant. The insurance company returns the check because it is made out to J instead of the company. What action should J take?",o:["Deposit the check in the agency account and send a company check","Return to the customer, collect a new check made out to the insurance company, and send it to the insurer","Send the original check back to the insurer with an explanation","Cancel the application"],a:1,e:"Premiums must be made payable to the insurer, not the agent. J must get a new check properly made out to the company and forward it."},
{c:"Retirement",q:"Q is severely injured in an automobile accident and becomes totally disabled. How many months must Q be disabled before being able to file for Social Security disability benefits?",o:["1 month","3 months","5 months","12 months"],a:2,e:"Social Security disability requires a 5-month waiting period of continuous disability before benefits can begin."},
{c:"Annuities",q:"K pays on a $20,000 20-Year Endowment policy for 10 years and dies from an automobile accident. How much will the insurance company pay the beneficiary?",o:["$10,000","$0","$20,000 death benefit","Cash value only"],a:2,e:"An endowment policy pays the face amount upon death regardless of when death occurs during the policy term. The full $20,000 death benefit is paid."},
{c:"Provisions",q:"Which of these Nonforfeiture Options continues a build-up of cash value?",o:["Extended term insurance","Cash surrender","Reduced Paid-Up","All nonforfeiture options build cash value"],a:2,e:"Reduced Paid-Up continues as a smaller whole life policy, so cash value continues to grow. Extended term is pure term — no cash value builds."},
{c:"Retirement",q:"An employee requested that the balance of her 401(k) account be sent directly to her in one lump sum. She immediately has the funds rolled over into an IRA. What is the tax consequence of the distribution sent to this employee?",o:["No tax consequence if rolled over within 60 days","Distribution is subject to federal income tax withholding","The rollover is completely tax-free with no withholding","Only the 10% penalty applies"],a:1,e:"When a distribution is paid directly to the employee, the plan must withhold 20% for federal income tax — even if the employee immediately rolls it over."},
{c:"Provisions",q:"Which of these provisions require proof of insurability after a policy has lapsed?",o:["Grace period","Automatic premium loan","Nonforfeiture option","Reinstatement"],a:3,e:"To reinstate a lapsed policy, the policyowner must provide evidence of insurability and pay all back premiums plus interest."},
{c:"Unfair Practices",q:"T cash surrenders a recently-issued whole life policy and requests that the proceeds be payable to an unrelated third party. T would likely be red-flagged for violation of:",o:["Replacement rules","Anti-money laundering rules","Insurable interest laws","ERISA"],a:1,e:"Surrendering a recently issued policy and directing proceeds to an unrelated third party raises anti-money laundering (AML) red flags."},
{c:"Retirement",q:"An IRA owner can start making withdrawals and NOT be subjected to a tax penalty beginning at what age?",o:["55","59½","62","65"],a:1,e:"IRA owners may take distributions beginning at age 59½ without the 10% early withdrawal penalty."},
{c:"Policy Types",q:"Whole Life insurance policies are contractually guaranteed to provide each of the following, EXCEPT:",o:["Level premiums for life","Cash value accumulation","Death benefit","Partial withdrawal features beyond a surrender charge period"],a:3,e:"Whole Life guarantees level premiums, cash value, and a death benefit — but NOT partial withdrawals. You can take loans or surrender, not partial withdrawals."},
{c:"Provisions",q:"All of these statements about the Waiver of Premium provision are correct, EXCEPT:",o:["There is a 6-month waiting period","Premiums are waived retroactively after the waiting period","Coverage continues during disability","Insured must be eligible for Social Security disability for claim to be accepted"],a:3,e:"The Waiver of Premium provision uses its own disability definition — it does NOT require the insured to qualify for Social Security disability."},
{c:"Underwriting",q:"Which of the following statements is CORRECT about an agent who is taking an insurance application?",o:["The agent may answer questions for the applicant","The agent should complete blank answers if the applicant is unsure","The agent should have the applicant initial any changes made on the application","The agent may skip irrelevant questions"],a:2,e:"Any corrections or changes on a life insurance application must be initialed by the applicant to verify accuracy."},
{c:"Policy Types",q:"S is close to retiring and would like to purchase a policy that will yield greater gains than bonds, but will still protect the principal with a minimum level of risk. Which product would S be advised to purchase?",o:["Variable Annuity","Fixed Annuity","Variable Universal Life","Equity index insurance"],a:3,e:"Equity Indexed Insurance (or Indexed Annuity) provides upside tied to a market index with a floor protecting principal — better than bonds but lower risk than variable products."},
{c:"Contracts",q:"Stranger-Owned Life Insurance (STOLI) is when a person purchases life insurance only to sell to a(n):",o:["Family member","Business partner","Third-party with no insurable interest","Charitable organization"],a:2,e:"STOLI involves purchasing a policy on someone's life with the intent to immediately sell it to a stranger who has no insurable interest in the insured."},
{c:"Underwriting",q:"Why is an applicant's signature required on a life insurance application?",o:["Required by FINRA","To give the agent authority to bind coverage","To attest that the statements on the application are accurate to the best of the applicant's knowledge","Required by the MIB"],a:2,e:"The applicant's signature attests that the information on the application is true and accurate to the best of their knowledge."},
{c:"Policy Types",q:"Which type of life policy contains a monthly mortality charge as well as self-directed investment choices?",o:["Universal Life","Variable Life","Variable Universal Life","Indexed Universal Life"],a:2,e:"Variable Universal Life (VUL) charges a monthly cost of insurance (mortality charge) and allows the policyowner to direct investments into separate accounts."},
{c:"Underwriting",q:"Any changes made on an insurance application requires the initials of whom?",o:["The agent only","The insurer's underwriter","Applicant","Both agent and applicant"],a:2,e:"All changes or corrections on a life insurance application must be initialed by the APPLICANT — not the agent alone."},
{c:"Policy Types",q:"A pilot applies for Life insurance. The insurer approves the application with a $10 additional monthly premium modification. The pilot declines the additional premium modification. The insurer will then likely issue the coverage with a(n):",o:["Declined application","Standard policy with no modification","Rating","Aviation Exclusion"],a:3,e:"If the applicant declines the extra premium for aviation risk, the insurer typically issues the policy with an aviation exclusion rider instead."},
{c:"Retirement",q:"What type of employee welfare plans are NOT subject to ERISA regulations?",o:["401(k) plans","Defined benefit pension plans","Church plans","Group health plans"],a:2,e:"Church plans (plans maintained by religious organizations) are specifically exempt from ERISA regulations."},
{c:"Policy Types",q:"A Return of Premium life insurance policy is best described as:",o:["Term plus a cash value rider","Whole life and Increasing term","Universal life with a return of premium rider","Variable life with a guaranteed benefit"],a:1,e:"A Return of Premium policy combines Whole Life with an Increasing Term rider. The death benefit grows to include all premiums paid."},
{c:"FL Regulations",q:"Which Federal law allows an insurer to obtain an inspection report on a potential insured?",o:["USA Patriot Act","ERISA","Fair Credit Reporting Act","Gramm-Leach-Bliley Act"],a:2,e:"The Fair Credit Reporting Act (FCRA) governs how consumer reports (including inspection reports) may be obtained and used by insurers."},
