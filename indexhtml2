{c:"Annuities",q:"T purchased a $100,000 single premium, Straight Life annuity 5 years ago and has received monthly payments since inception. If T dies, the insurance company:",o:["Must pay remaining value to heirs","Must refund unearned premiums","Must pay for 20 years total","Does NOT have to make any further payments"],a:3,e:"A Straight Life (Life Only) annuity provides income only while the annuitant is alive. There is no death benefit or residual value — payments stop at death."},
];

// ═══════════════════════════════════
// STATE
// ═══════════════════════════════════
function loadState() {
  return {
    seen: JSON.parse(localStorage.getItem('fl214_seen') || '[]'),
    correct: parseInt(localStorage.getItem('fl214_correct') || '0'),
    totalAnswered: parseInt(localStorage.getItem('fl214_answered') || '0'),
  };
}
function saveState(s) {
  localStorage.setItem('fl214_seen', JSON.stringify(s.seen));
  localStorage.setItem('fl214_correct', s.correct);
  localStorage.setItem('fl214_answered', s.totalAnswered);
}

let SESSION = { questions:[], idx:0, correct:0, wrong:0, skipped:0, answered:false };

function shuffle(arr) {
  const a=[...arr];
  for(let i=a.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[a[i],a[j]]=[a[j],a[i]];}
  return a;
}

function startSession() {
  const st = loadState();
  // Prioritize unseen questions, then cycle through seen ones
  const unseen = QBANK.map((q,i)=>({...q,origIdx:i})).filter(q=>!st.seen.includes(q.origIdx));
  const seen   = QBANK.map((q,i)=>({...q,origIdx:i})).filter(q=>st.seen.includes(q.origIdx));

  let pool = [];
  if (unseen.length >= 100) {
    pool = shuffle(unseen).slice(0,100);
  } else {
    // Use all unseen + fill rest with shuffled seen
    pool = [...shuffle(unseen), ...shuffle(seen)].slice(0,100);
  }

  SESSION = { questions: pool, idx:0, correct:0, wrong:0, skipped:0, answered:false };
  showScreen('quiz');
  updateSessionTag();
  renderQ();
}

function updateSessionTag() {
  const st = loadState();
  const remaining = QBANK.length - st.seen.length;
  document.getElementById('session-tag').textContent =
    `${Math.min(remaining, 100)} new · ${361 - Math.min(remaining, 361)} seen`;
}

function renderQ() {
  const q = SESSION.questions[SESSION.idx];
  SESSION.answered = false;
  const total = SESSION.questions.length;

  document.getElementById('prog-text').textContent = `${SESSION.idx+1} / ${total}`;
  document.getElementById('prog-fill').style.width = `${(SESSION.idx/total)*100}%`;
  document.getElementById('cat-tag').textContent = q.c;
  document.getElementById('q-num').textContent = `Question ${SESSION.idx+1}`;
  document.getElementById('q-text').textContent = q.q;
  document.getElementById('lc').textContent = `✓ ${SESSION.correct}`;
  document.getElementById('lw').textContent = `✗ ${SESSION.wrong}`;
  document.getElementById('ls').textContent = `↷ ${SESSION.skipped}`;

  const ans = document.getElementById('answers');
  ans.innerHTML='';
  const LETTERS=['A','B','C','D','E'];
  // Shuffle the answer options but track the correct one
  const indexed = q.o.map((opt,i)=>({opt,isCorrect:(i===q.a)}));
  const shuffled = shuffle(indexed);
  let correctShuffledIdx = shuffled.findIndex(x=>x.isCorrect);
  SESSION._correctIdx = correctShuffledIdx;
  SESSION._shuffled = shuffled;

  shuffled.forEach((item,i)=>{
    const btn=document.createElement('button');
    btn.className='ans-btn';
    btn.innerHTML=`<span class="ltr">${LETTERS[i]}</span><span>${item.opt}</span>`;
    btn.onclick=()=>selectA(i);
    ans.appendChild(btn);
  });

  document.getElementById('fb').className='fb-box';
  document.getElementById('fb').innerHTML='';
  document.getElementById('next-btn').style.display='none';
}

function selectA(chosen) {
  if(SESSION.answered) return;
  SESSION.answered=true;
  const q = SESSION.questions[SESSION.idx];
  const correct = SESSION._correctIdx;
  const btns = document.querySelectorAll('.ans-btn');
  btns.forEach((btn,i)=>{
    btn.disabled=true;
    if(i===correct) btn.classList.add('cor');
    else if(i===chosen && chosen!==correct) btn.classList.add('wrg');
    else btn.classList.add('dim');
  });

  const fb=document.getElementById('fb');
  const st=loadState();
  if(!st.seen.includes(q.origIdx)) { st.seen.push(q.origIdx); }
  st.totalAnswered++;

  if(chosen===correct){
    SESSION.correct++;
    st.correct++;
    fb.className='fb-box cor';
    fb.innerHTML=`<div class="fb-title">✓ Correct!</div><div>${q.e}</div>`;
  } else {
    SESSION.wrong++;
    fb.className='fb-box wrg';
    fb.innerHTML=`<div class="fb-title">✗ Incorrect</div><div><strong>Correct answer:</strong> ${SESSION._shuffled[correct].opt}</div><div class="fb-ref" style="margin-top:10px;padding-top:10px;border-top:1px solid rgba(255,255,255,.06);color:#94a3b8;font-size:13px;">${q.e}</div>`;
  }
  saveState(st);
  document.getElementById('next-btn').style.display='inline-block';
}

function skipQ() {
  if(SESSION.answered) return;
  SESSION.skipped++;
  nextQ();
}

function nextQ() {
  SESSION.idx++;
  if(SESSION.idx>=SESSION.questions.length) { showResults(); return; }
  renderQ();
}

function showResults() {
  showScreen('results');
  const attempted = SESSION.correct + SESSION.wrong;
  const pct = attempted>0 ? Math.round(SESSION.correct/attempted*100) : 0;
  const passed = pct>=70;

  const icons = pct>=90?'🏆':pct>=80?'🎉':pct>=70?'👍':pct>=50?'📚':'💪';
  const titles = pct>=90?'Outstanding!':pct>=80?'Great Work!':pct>=70?'You Passed!':pct>=50?'Keep Grinding':'Keep Pushing!';
  document.getElementById('ri').textContent=icons;
  document.getElementById('rt').textContent=titles;
  document.getElementById('rs').textContent=`You answered ${SESSION.correct} of ${attempted} attempted questions correctly.`;
  document.getElementById('rp').textContent=pct+'%';

  const pl=document.getElementById('rl');
  pl.textContent=passed?'✓ Passing Score — you would pass the real exam!':'✗ Below 70% — review weak areas and try again.';
  pl.className='pass-label '+(passed?'p':'f');

  document.getElementById('rc').textContent=SESSION.correct;
  document.getElementById('rw').textContent=SESSION.wrong;
  document.getElementById('rsk').textContent=SESSION.skipped;

  const st=loadState();
  const seenPct=Math.round(st.seen.length/QBANK.length*100);
  document.getElementById('prog-note').textContent=
    `Overall progress: ${st.seen.length} / ${QBANK.length} questions seen (${seenPct}%)`;
}

function goHome() {
  showScreen('home');
  updateHome();
}

function updateHome() {
  const st=loadState();
  const pct=Math.round(st.seen.length/QBANK.length*100);
  document.getElementById('overall-fill').style.width=pct+'%';
  document.getElementById('stat-seen').textContent=st.seen.length;
  document.getElementById('stat-correct').textContent=st.correct;
  const scorePct=st.totalAnswered>0?Math.round(st.correct/st.totalAnswered*100)+'%':'—';
  document.getElementById('stat-score').textContent=scorePct;

  const unseen=QBANK.length-st.seen.length;
  const note = unseen>0
    ? `${unseen} questions you haven't seen yet — next session will prioritize those.`
    : `You've seen all 361 questions! Sessions will cycle through the full bank.`;
  document.getElementById('session-note').textContent=note;
}

function resetAll() {
  if(!confirm('Reset all progress? This cannot be undone.')) return;
  localStorage.removeItem('fl214_seen');
  localStorage.removeItem('fl214_correct');
  localStorage.removeItem('fl214_answered');
  updateHome();
}

function showScreen(id) {
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  window.scrollTo(0,0);
}

// Init
updateHome();
</script>

